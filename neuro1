<section class="page-section anchor" id="brain-lobes">
  <div class="section-header">
    <span class="section-tag">1.01</span>
    <h2 class="section-title">Brain Lobes & Cortical Functions</h2>
  </div>

  <div class="tbl-wrap">
    <table>
      <tr><th>Lobe</th><th>Structure</th><th>Function</th><th>Clinical Deficit</th></tr>
      <tr><td rowspan="4" class="hl" style="background:#fff3e0"><strong>Frontal</strong></td><td>Motor Cortex (Precentral Gyrus)</td><td>Plans & executes voluntary movements</td><td>Contralateral weakness</td></tr>
