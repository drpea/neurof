<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Neurosciences 1 — High-Yield Reviewer</title>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #f7f4ef;
  --surface: #ffffff;
  --surface2: #f0ece4;
  --border: #e2d9cc;
  --text: #2c2416;
  --text-muted: #7a6e5f;
  --accent: #2d6a6a;
  --accent2: #8b3a3a;
  --accent3: #5a4a8a;
  --accent4: #1a5276;
  --green: #1e6b4a;
  --yellow-bg: #fff9e6;
  --yellow-border: #f0d060;
  --red-bg: #fff0f0;
  --red-border: #e8a0a0;
  --blue-bg: #eef4fb;
  --blue-border: #a0c0e8;
  --purple-bg: #f2eefb;
  --purple-border: #c0a8e8;
  --green-bg: #edf7f0;
  --green-border: #90cca8;
  --teal-bg: #e6f4f4;
  --teal-border: #7fc0c0;
  --sidebar-w: 260px;
}

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
font-family: ‘DM Sans’, sans-serif;
background: var(–bg);
color: var(–text);
font-size: 14px;
line-height: 1.6;
}

/* SIDEBAR */
#sidebar {
position: fixed;
left: 0; top: 0;
width: var(–sidebar-w);
height: 100vh;
background: #1e2a2a;
color: #c8d8d8;
overflow-y: auto;
z-index: 100;
padding-bottom: 40px;
}

#sidebar-header {
padding: 22px 18px 14px;
border-bottom: 1px solid #2e3e3e;
}

#sidebar-header h1 {
font-family: ‘Lora’, serif;
font-size: 14px;
font-weight: 700;
color: #e8f4f4;
letter-spacing: 0.02em;
}

#sidebar-header p {
font-size: 11px;
color: #8aacac;
margin-top: 4px;
}

.nav-section {
padding: 10px 0 4px;
}

.nav-label {
font-size: 9px;
font-weight: 600;
letter-spacing: 0.12em;
text-transform: uppercase;
color: #5a7a7a;
padding: 6px 18px 4px;
}

.nav-item {
display: block;
padding: 7px 18px;
color: #a8c4c4;
text-decoration: none;
font-size: 12.5px;
transition: all 0.15s;
cursor: pointer;
border-left: 3px solid transparent;
}

.nav-item:hover, .nav-item.active {
background: #253535;
color: #e8f4f4;
border-left-color: #5ab0b0;
}

.nav-item.sub {
padding-left: 28px;
font-size: 12px;
color: #8aacac;
}

/* MAIN */
#main {
margin-left: var(–sidebar-w);
padding: 0 0 80px;
min-height: 100vh;
}

/* TOP BAR */
#topbar {
background: var(–accent);
color: white;
padding: 14px 40px;
display: flex;
align-items: center;
gap: 16px;
position: sticky;
top: 0;
z-index: 50;
}

#topbar h2 {
font-family: ‘Lora’, serif;
font-size: 18px;
font-weight: 600;
}

#topbar span {
font-size: 12px;
opacity: 0.8;
background: rgba(255,255,255,0.15);
padding: 3px 10px;
border-radius: 20px;
}

/* SECTIONS */
.page-section {
padding: 40px 40px 20px;
border-bottom: 2px solid var(–border);
}

.section-header {
display: flex;
align-items: center;
gap: 12px;
margin-bottom: 24px;
}

.section-tag {
background: var(–accent);
color: white;
font-size: 10px;
font-weight: 600;
letter-spacing: 0.1em;
text-transform: uppercase;
padding: 3px 10px;
border-radius: 4px;
}

.section-tag.red { background: var(–accent2); }
.section-tag.purple { background: var(–accent3); }
.section-tag.navy { background: var(–accent4); }
.section-tag.green { background: var(–green); }

.section-title {
font-family: ‘Lora’, serif;
font-size: 22px;
font-weight: 700;
color: var(–text);
}

/* CARDS & CALLOUTS */
.card-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
gap: 16px;
margin-bottom: 20px;
}

.card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 18px;
box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.card h4 {
font-family: ‘Lora’, serif;
font-size: 14px;
font-weight: 600;
margin-bottom: 10px;
color: var(–accent);
}

.card.red h4 { color: var(–accent2); border-bottom: 2px solid var(–red-border); padding-bottom: 6px; }
.card.purple h4 { color: var(–accent3); border-bottom: 2px solid var(–purple-border); padding-bottom: 6px; }
.card.green h4 { color: var(–green); border-bottom: 2px solid var(–green-border); padding-bottom: 6px; }
.card.teal h4 { color: var(–accent); border-bottom: 2px solid var(–teal-border); padding-bottom: 6px; }

.callout {
border-radius: 8px;
padding: 14px 18px;
margin-bottom: 16px;
border-left: 4px solid;
font-size: 13.5px;
}

.callout.yellow { background: var(–yellow-bg); border-color: var(–yellow-border); }
.callout.red { background: var(–red-bg); border-color: var(–red-border); }
.callout.blue { background: var(–blue-bg); border-color: var(–blue-border); }
.callout.green { background: var(–green-bg); border-color: var(–green-border); }
.callout.purple { background: var(–purple-bg); border-color: var(–purple-border); }
.callout.teal { background: var(–teal-bg); border-color: var(–teal-border); }

.callout strong { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; opacity: 0.7; }

/* TABLES */
.tbl-wrap { overflow-x: auto; margin-bottom: 20px; border-radius: 10px; border: 1px solid var(–border); box-shadow: 0 1px 4px rgba(0,0,0,0.04); }

table {
width: 100%;
border-collapse: collapse;
font-size: 13px;
background: var(–surface);
}

th {
background: var(–accent);
color: white;
padding: 10px 14px;
text-align: left;
font-weight: 600;
font-size: 12px;
letter-spacing: 0.04em;
}

th.red { background: var(–accent2); }
th.purple { background: var(–accent3); }
th.navy { background: var(–accent4); }
th.green { background: var(–green); }

td {
padding: 9px 14px;
border-bottom: 1px solid var(–border);
vertical-align: top;
}

tr:last-child td { border-bottom: none; }
tr:nth-child(even) td { background: #fafaf8; }

td.hl { font-weight: 600; color: var(–accent); }
td.hl-red { font-weight: 600; color: var(–accent2); }
td.hl-purple { font-weight: 600; color: var(–accent3); }

/* BADGES */
.badge {
display: inline-block;
padding: 2px 8px;
border-radius: 4px;
font-size: 11px;
font-weight: 600;
margin: 1px;
}

.badge.teal { background: var(–teal-bg); color: var(–accent); border: 1px solid var(–teal-border); }
.badge.red { background: var(–red-bg); color: var(–accent2); border: 1px solid var(–red-border); }
.badge.purple { background: var(–purple-bg); color: var(–accent3); border: 1px solid var(–purple-border); }
.badge.green { background: var(–green-bg); color: var(–green); border: 1px solid var(–green-border); }
.badge.yellow { background: var(–yellow-bg); color: #7a5a00; border: 1px solid var(–yellow-border); }

/* STAR */
.star { color: #d4a017; }

/* ALGORITHM BOX */
.algo {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 20px;
margin-bottom: 20px;
}

.algo h4 {
font-family: ‘Lora’, serif;
font-size: 15px;
color: var(–accent);
margin-bottom: 14px;
padding-bottom: 8px;
border-bottom: 1px solid var(–border);
}

.flow {
display: flex;
align-items: flex-start;
gap: 0;
flex-direction: column;
}

.flow-step {
display: flex;
align-items: flex-start;
gap: 12px;
width: 100%;
position: relative;
}

.flow-step:not(:last-child)::after {
content: ‘’;
position: absolute;
left: 19px;
top: 40px;
bottom: -10px;
width: 2px;
background: var(–border);
}

.flow-num {
width: 38px;
height: 38px;
min-width: 38px;
background: var(–accent);
color: white;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
font-weight: 700;
font-size: 14px;
margin-bottom: 18px;
}

.flow-num.red { background: var(–accent2); }
.flow-num.purple { background: var(–accent3); }

.flow-content {
background: var(–surface2);
border-radius: 8px;
padding: 10px 14px;
flex: 1;
margin-bottom: 10px;
border: 1px solid var(–border);
}

.flow-content h5 { font-weight: 600; font-size: 13px; color: var(–accent); margin-bottom: 4px; }

/* MCQ */
.mcq-section { padding: 40px; }

.mcq {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 20px;
margin-bottom: 16px;
box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.mcq-num {
font-size: 10px;
font-weight: 700;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–text-muted);
margin-bottom: 6px;
}

.mcq-q {
font-size: 14px;
font-weight: 500;
margin-bottom: 12px;
color: var(–text);
line-height: 1.5;
}

.mcq-opts {
display: grid;
gap: 6px;
}

.mcq-opt {
padding: 8px 12px;
border: 1px solid var(–border);
border-radius: 6px;
font-size: 13px;
cursor: pointer;
transition: all 0.15s;
background: var(–bg);
display: flex;
gap: 8px;
}

.mcq-opt span.letter {
font-weight: 700;
color: var(–accent);
min-width: 18px;
}

.mcq-opt:hover { border-color: var(–accent); background: var(–teal-bg); }
.mcq-opt.correct { background: var(–green-bg) !important; border-color: var(–green-border) !important; }
.mcq-opt.incorrect { background: var(–red-bg) !important; border-color: var(–red-border) !important; }

.mcq-explain {
margin-top: 12px;
padding: 10px 14px;
background: var(–blue-bg);
border: 1px solid var(–blue-border);
border-radius: 6px;
font-size: 13px;
display: none;
}

.mcq-explain.show { display: block; }

/* DIAGRAM */
.diagram-box {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 20px;
margin-bottom: 20px;
text-align: center;
}

.diagram-title {
font-family: ‘Lora’, serif;
font-size: 14px;
font-weight: 600;
margin-bottom: 14px;
color: var(–accent);
}

/* MNEMONIC */
.mnemonic {
background: linear-gradient(135deg, #f0f8f0, #e8f4e8);
border: 2px dashed var(–green-border);
border-radius: 10px;
padding: 16px 20px;
margin-bottom: 16px;
}

.mnemonic-label {
font-size: 10px;
font-weight: 700;
letter-spacing: 0.1em;
text-transform: uppercase;
color: var(–green);
margin-bottom: 6px;
}

.mnemonic-text {
font-family: ‘Lora’, serif;
font-size: 14px;
font-style: italic;
color: #1e4a2e;
margin-bottom: 6px;
}

.mnemonic-expand {
font-size: 12.5px;
color: var(–text-muted);
}

/* COMPARE TABLE */
.compare {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 12px;
margin-bottom: 20px;
}

.compare-col {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
overflow: hidden;
}

.compare-col-head {
padding: 10px 16px;
font-weight: 700;
font-size: 13px;
color: white;
letter-spacing: 0.04em;
}

.compare-col-head.teal { background: var(–accent); }
.compare-col-head.red { background: var(–accent2); }
.compare-col-head.purple { background: var(–accent3); }

.compare-col-body {
padding: 12px 16px;
}

.compare-col-body li {
list-style: none;
padding: 3px 0;
font-size: 13px;
border-bottom: 1px solid var(–border);
}

.compare-col-body li:last-child { border-bottom: none; }
.compare-col-body li::before { content: ’• ’; color: var(–accent); }

/* TWO COL LAYOUT */
.two-col {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
margin-bottom: 20px;
}

/* BUZZWORDS */
.bz-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
gap: 10px;
margin-bottom: 20px;
}

.bz-item {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 8px;
padding: 12px 14px;
display: flex;
flex-direction: column;
gap: 4px;
}

.bz-term {
font-family: ‘DM Mono’, monospace;
font-size: 12px;
font-weight: 500;
color: var(–accent);
background: var(–teal-bg);
padding: 2px 8px;
border-radius: 4px;
width: fit-content;
}

.bz-def {
font-size: 12.5px;
color: var(–text);
}

/* PROGRESS BAR */
#score-bar {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 16px 20px;
margin-bottom: 20px;
display: flex;
align-items: center;
gap: 16px;
}

#score-display { font-family: ‘Lora’, serif; font-size: 18px; font-weight: 700; color: var(–accent); }
#score-label { font-size: 13px; color: var(–text-muted); }

/* SCROLL ANCHOR */
.anchor { scroll-margin-top: 70px; }

/* RESPONSIVE */
@media (max-width: 800px) {
:root { –sidebar-w: 0px; }
#sidebar { display: none; }
.two-col, .compare { grid-template-columns: 1fr; }
.page-section { padding: 24px 16px; }
}

/* DIVIDER */
.divider {
height: 1px;
background: var(–border);
margin: 20px 0;
}

h3 {
font-family: ‘Lora’, serif;
font-size: 16px;
font-weight: 600;
color: var(–text);
margin: 20px 0 10px;
padding-left: 10px;
border-left: 3px solid var(–accent);
}

h3.red { border-color: var(–accent2); }
h3.purple { border-color: var(–accent3); }

p { margin-bottom: 10px; }
ul, ol { padding-left: 20px; margin-bottom: 10px; }
li { margin-bottom: 3px; }

code {
background: #e8e0d0;
padding: 1px 5px;
border-radius: 3px;
font-family: ‘DM Mono’, monospace;
font-size: 12px;
}

/* TABS */
.tab-bar {
display: flex;
gap: 0;
border-bottom: 2px solid var(–border);
margin-bottom: 20px;
}

.tab-btn {
padding: 9px 18px;
font-size: 13px;
font-weight: 500;
color: var(–text-muted);
cursor: pointer;
border-bottom: 2px solid transparent;
margin-bottom: -2px;
transition: all 0.15s;
background: none;
border-top: none;
border-left: none;
border-right: none;
font-family: ‘DM Sans’, sans-serif;
}

.tab-btn.active { color: var(–accent); border-bottom-color: var(–accent); font-weight: 600; }
.tab-pane { display: none; }
.tab-pane.active { display: block; }

/* EYE DIAGRAM */
.eye-row {
display: flex;
align-items: center;
gap: 10px;
padding: 6px 0;
border-bottom: 1px solid var(–border);
font-size: 13px;
}
.eye-icon {
font-size: 18px;
letter-spacing: -2px;
}
.eye-label { color: var(–text-muted); font-size: 11px; min-width: 80px; }

/* SPINAL DIAGRAM */
.sc-diagram {
display: grid;
grid-template-columns: 80px 1fr;
gap: 8px;
font-size: 12px;
}
.sc-label { text-align: right; font-weight: 600; color: var(–text-muted); padding-top: 4px; }
.sc-bar {
height: 26px;
border-radius: 4px;
display: flex;
align-items: center;
padding-left: 10px;
font-size: 12px;
font-weight: 500;
color: white;
}

/* VISUAL PATHWAY */
.vp-step {
display: flex;
align-items: center;
gap: 8px;
margin-bottom: 6px;
}
.vp-dot {
width: 10px;
height: 10px;
border-radius: 50%;
min-width: 10px;
}
.vp-arrow {
color: var(–text-muted);
font-size: 16px;
}
</style>

</head>
