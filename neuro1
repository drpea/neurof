      <tr><td>Inferior Temporal Cortex</td><td>Visual identification of objects (memory)</td><td>Prosopagnosia, agnosia</td></tr>
      <tr><td rowspan="2" class="hl" style="background:#f2eefb"><strong>Occipital</strong></td><td>Primary Visual Cortex (BA 17)</td><td>Projection area for visual info</td><td>Cortical blindness</td></tr>
      <tr><td>Visual Association Cortex</td><td>Processes components of visual info</td><td>Visual agnosia</td></tr>
    </table>
  </div>

  <h3>Other Forebrain Structures</h3>
  <div class="tbl-wrap">
