x solid var(--border); font-size: 0.84rem; }\n  .gcs-row:last-child { border-bottom: none; }\n  .gcs-score { font-weight: 800; font-family: 'JetBrains Mono', monospace; color: var(--accent1); }\n\n  \/* REFLEX MAP *\/\n  .reflex-map { display: flex; flex-direction: column; gap: 6px; }\n  .reflex-item { display: flex; align-items: center; gap: 12px; padding: 8px 14px; background: #fff; border: 1px solid var(--border); border-radius: 8px; font-size: 0.86rem; }\n  .reflex-nerve { font-family: 'JetBrains Mono', monospace; font-weight: 700; color: var(--accent2); min-width: 60px; }\n  .reflex-muscle { font-weight: 600; min-width: 100px; }\n  .reflex-action { color: var(--text-light); }\n\n  \/* PUPIL VISUAL TABLE *\/\n  .pupil-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }\n  .pupil-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 14px; text-align: center; }\n  .pupil-emoji { font-size: 2.2rem; display: block; margin-bottom: 6px; }\n  .pupil-site { font-weight: 800; font-size: 0.85rem; color: var(--nav-bg); }\n  .pupil-desc { font-size: 0.78rem; color: var(--text-light); margin-top: 4px; }\n\n  \/* LOCALIZATION SUMMARY TABLE *\/\n  .loc-table { font-size: 0.8rem; }\n  .loc-table th { font-size: 0.72rem; }\n\n  hr { border: none; border-top: 1px solid var(--border); margin: 28px 0; }\n\n  strong { font-weight: 700; }\n  em { font-style: italic; }\n  ul { padding-left: 20px; }\n  li { margin-bottom: 4px; font-size: 0.88rem; }\n\n  .tag {\n    display: inline-block;\n    background: var(--tag-bg);\n    color: var(--tag-text);\n    font-size: 0.72rem;\n    font-weight: 700;\n    padding: 2px 8px;\n    border-radius: 4px;\n    margin-left: 6px;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n  }\n  .tag.red { background: #fff0f0; color: var(--accent1); }\n  .tag.green { background: #eafaf1; color: #1a6b38; }\n\n  \/* NERVE ROOT TABLE *\/\n  .nerve-duo { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }\n\n  @media(max-width: 600px) {\n    .tab-content { padding: 20px 16px; }\n    .site-header { padding: 14px 16px; }\n    .gcs-wrap { grid-template-columns: 1fr; }\n    .nerve-duo { grid-template-columns: 1fr; }\n    .compare-wrap { grid-template-columns: 1fr; }\n    .sperm-grid { grid-template-columns: repeat(3, 1fr); }\n    .pupil-grid { grid-template-columns: 1fr 1fr; }\n    .pathway-vis { flex-direction: column; }\n    .path-step { border-right: none; border-bottom: 2px dashed var(--border); }\n  }\n\n  .scroll-top {\n    position: fixed;\n    bottom: 30px;\n    right: 30px;\n    background: var(--nav-bg);\n    color: #fff;\n    border: none;\n    border-radius: 50%;\n    width: 44px;\n    height: 44px;\n    font-size: 1.2rem;\n    cursor: pointer;\n    box-shadow: 0 4px 14px rgba(0,0,0,0.25);\n    z-index: 200;\n    transition: all 0.2s;\n  }\n  .scroll-top:hover { background: var(--accent1); transform: translateY(-2px); }\n<\/style>\n<\/head>\n<body>\n\n<header class=\"site-header\">\n  <h1>🧠 Neurosciences 1 — High Yield Reviewer<\/h1>\n  <span>⭐ Board-Level<\/span>\n<\/header>\n\n<nav class=\"tab-nav\">\n  <button class=\"tab-btn active\" onclick=\"showTab('s01')\">2.01 Somatosensory<\/button>\n  <button class=\"tab-btn\" onclick=\"showTab('s02')\">2.02 UMN Weakness<\/button>\n  <button class=\"tab-btn\" onclick=\"showTab('s03')\">2.03 LMN Weakness<\/button>\n  <button class=\"tab-btn\" onclick=\"showTab('s04')\">2.04 Altered Sensorium<\/button>\n  <button class=\"tab-btn\" onclick=\"showTab('mcq')\">📝 MCQ Practice<\/button>\n  <button class=\"tab-btn\" onclick=\"showTab('buzz')\">⚡ Buzzwords<\/button>\n  <button class=\"tab-btn\" onclick=\"showTab('flow')\">🗺 Algorithms<\/button>\n<\/nav>\n\n<!-- ============================================================ -->\n<!-- TAB 1: SOMATOSENSORY -->\n<!-- ============================================================ -->\n<div id=\"s01\" class=\"tab-content active\">\n  <h2 class=\"section-title\">Clinical Approach to Somatosensory Symptoms<\/h2>\n  <p class=\"section-subtitle\">4-step diagnostic approach · Sensory pathways · Localization patterns<\/p>\n\n  <!-- 4 STEPS -->\n  <h3 class=\"subsection\">4-Step Diagnostic Approach<\/h3>\n  <div class=\"steps\">\n    <div class=\"step\">\n      <div class=\"step-num\">1<\/div>\n      <div class=\"step-content\"><strong>Elicit Chief Complaint<\/strong> — Clarify true symptom (e.g., \"numbness\" may mean weakness). Is it focal\/neurologic\/non-neurologic? Ask: onset, distribution, progression.<\/div>\n    <\/div>\n    <div class=\"step\">\n      <div class=\"step-num\">2<\/div>\n      <div class=\"step-content\"><strong>Localize the Lesion<\/strong> — Which sensory pathway is affected (Spinothalamic vs DCML)? Is it CNS or PNS? Pattern of involvement?<\/div>\n    <\/div>\n    <div class=\"step\">\n      <div class=\"step-num\">3<\/div>\n      <div class=\"step-content\"><strong>Determine Cause<\/strong> — Temporal profile: Acute → vascular\/demyelination; Chronic → degenerative\/tumor. Look for associated features (aphasia, cranial nerve deficits).<\/div>\n    <\/div>\n    <div class=\"step\">\n      <div class=\"step-num\">4<\/div>\n      <div class=\"step-content\"><strong>Investigate & Manage<\/strong> — CT\/MRI, labs (B12, heavy metals), EMG\/NCV, LP if myelopathy suspected.<\/div>\n    <\/div>\n  <\/div>\n\n  <!-- SENSORY TERMINOLOGY -->\n  <h3 class=\"subsection\">Sensory Terminology <span class=\"tag red\">Must Memorize<\/span><\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Term<\/th><th>Type<\/th><th>Definition<\/th><th>Key Clue<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Numbness<\/strong><\/td><td><span class=\"badge badge-gray\">NEGATIVE<\/span><\/td><td>Partial or complete loss of sensation<\/td><td>Stroke → complete loss<\/td><\/tr>\n        <tr><td><strong>Paresthesia<\/strong><\/td><td><span class=\"badge badge-blue\">POSITIVE<\/span><\/td><td>Spontaneous tingling\/pins-and-needles — NOT unpleasant<\/td><td>Peripheral neuropathy<\/td><\/tr>\n        <tr><td><strong>Dysesthesia<\/strong><\/td><td><span class=\"badge badge-blue\">POSITIVE<\/span><\/td><td>Abnormal UNPLEASANT sensation — patient can't sleep<\/td><td>Radiculopathy<\/td><\/tr>\n        <tr><td><strong>Allodynia<\/strong><\/td><td><span class=\"badge badge-red\">POSITIVE<\/span><\/td><td>Pain from normally NON-painful stimulus (e.g., cotton touch)<\/td><td>Trigeminal neuralgia<\/td><\/tr>\n        <tr><td><strong>Hyperalgesia \/ Hyperpathia<\/strong><\/td><td><span class=\"badge badge-red\">POSITIVE<\/span><\/td><td>Exaggerated pain from a normally painful stimulus<\/td><td><\/td><\/tr>\n        <tr><td><strong>Hyperesthesia<\/strong><\/td><td><span class=\"badge badge-blue\">POSITIVE<\/span><\/td><td>Exaggerated perception of touch stimulus<\/td><td><\/td><\/tr>\n        <tr><td><strong>Hypesthesia<\/strong><\/td><td><span class=\"badge badge-gray\">NEGATIVE<\/span><\/td><td>Decreased sensitivity to sensory inputs<\/td><td><\/td><\/tr>\n        <tr><td><strong>Causalgia<\/strong><\/td><td><span class=\"badge badge-red\">POSITIVE<\/span><\/td><td>Burning pain in distribution of one or more peripheral nerves<\/td><td><\/td><\/tr>\n        <tr><td><strong>Anesthesia<\/strong><\/td><td><span class=\"badge badge-gray\">NEGATIVE<\/span><\/td><td>Reduced perception of ALL sensations (mainly touch)<\/td><td><\/td><\/tr>\n        <tr><td><strong>Pallanesthesia<\/strong><\/td><td><span class=\"badge badge-gray\">NEGATIVE<\/span><\/td><td>Loss of vibration perception<\/td><td><\/td><\/tr>\n        <tr><td><strong>Analgesia<\/strong><\/td><td><span class=\"badge badge-gray\">NEGATIVE<\/span><\/td><td>Loss of pain perception<\/td><td><\/td><\/tr>\n        <tr><td><strong>Hypoalgesia \/ Hypalgesia<\/strong><\/td><td><span class=\"badge badge-gray\">NEGATIVE<\/span><\/td><td>Decreased sensitivity to painful stimuli (raised threshold)<\/td><td><\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- ROOT WORD TABLE -->\n  <div class=\"grid-3\">\n    <div class=\"card\">\n      <div class=\"card-title\"><span class=\"icon\">🔤<\/span> Root Word: -esthesia<\/div>\n      <p style=\"font-size:0.88rem;\">Refers to <strong>touch<\/strong> (e.g., hypesthesia, anesthesia, hyperesthesia)<\/p>\n    <\/div>\n    <div class=\"card\">\n      <div class=\"card-title\"><span class=\"icon\">🌡️<\/span> Root Word: Therm-<\/div>\n      <p style=\"font-size:0.88rem;\">Refers to <strong>temperature<\/strong> (e.g., thermhypesthesia, thermanesthesia)<\/p>\n    <\/div>\n    <div class=\"card\">\n      <div class=\"card-title\"><span class=\"icon\">⚡<\/span> Root Word: -algesia<\/div>\n      <p style=\"font-size:0.88rem;\">Refers to <strong>pain<\/strong> (e.g., hypalgesia, analgesia, hyperalgesia)<\/p>\n    <\/div>\n  <\/div>\n\n  <!-- SENSORY PATHWAYS -->\n  <h3 class=\"subsection\">Two Major Sensory Pathways <span class=\"tag red\">MUST KNOW<\/span><\/h3>\n  <div class=\"grid-2\">\n    <div class=\"card\">\n      <div class=\"card-title\" style=\"color:var(--accent1);\">⚡ Spinothalamic Tract (Anterolateral)<\/div>\n      <div class=\"tbl-wrap\">\n        <table>\n          <tr><th>Tract<\/th><th>Modality<\/th><\/tr>\n          <tr><td>Lateral ST<\/td><td><strong>Pain, Temperature, Itch<\/strong><\/td><\/tr>\n          <tr><td>Anterior ST<\/td><td>Crude (non-discriminatory) touch, Pressure<\/td><\/tr>\n        <\/table>\n      <\/div>\n      <div class=\"alert alert-warn\">\n        <span class=\"label\">⭐ Key Feature<\/span>\n        Crosses midline <strong>1–2 spinal levels ABOVE entry<\/strong> in the spinal cord → Lesion is localized 1-2 levels ABOVE the dermatome where sensation is lost\n      <\/div>\n      <p style=\"font-size:0.84rem;\"><strong>Fiber type:<\/strong> Group III (thinly myelinated) and IV (unmyelinated)<\/p>\n      <div style=\"margin-top:10px;font-size:0.84rem;\">\n        <strong>Course:<\/strong> DRG → Dorsal horn → Cross in anterior white commissure → Contralateral anterolateral quadrant → Contralateral thalamus (VPL) → Parietal cortex\n      <\/div>\n    <\/div>\n    <div class=\"card\">\n      <div class=\"card-title\" style=\"color:var(--accent2);\">🎯 Dorsal Column–Medial Lemniscus (DCML)<\/div>\n      <p style=\"font-size:0.88rem; margin-bottom:10px;\"><strong>Modalities:<\/strong> Vibration · Proprioception · 2-point discrimination · Stereognosis · Fine touch<\/p>\n      <div class=\"alert alert-info\">\n        <span class=\"label\">⭐ Key Feature<\/span>\n        Ascends <strong>IPSILATERAL<\/strong> first → crosses midline at the <strong>MEDULLA<\/strong>\n      <\/div>\n      <p style=\"font-size:0.84rem;\"><strong>Fiber type:<\/strong> Group II (thickly myelinated — fast!)<\/p>\n      <div style=\"margin-top:10px;font-size:0.84rem;\">\n        <strong>Below T6:<\/strong> Fasciculus gracilis (🍃 gracilis = graceful legs)<br>\n        <strong>Above T6 (cervical\/upper thoracic):<\/strong> Fasciculus cuneatus\n      <\/div>\n      <div style=\"margin-top:10px;font-size:0.84rem;\">\n        <strong>Course:<\/strong> DRG → Nucleus gracilis\/cuneatus (ipsilateral) → Decussate at medulla → Medial lemniscus → Contralateral VPL thalamus → Parietal cortex\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <!-- PATHWAY ORDER -->\n  <div class=\"pathway-vis\">\n    <div class=\"path-step\"><span class=\"order\">1st ORDER<\/span>Peripheral Nerve → DRG<span class=\"loc\">DRG (pseudounipolar)<\/span><\/div>\n    <div class=\"path-step\"><span class=\"order\">2nd ORDER<\/span>Spinal Cord \/ Brainstem<span class=\"loc\">Dorsal horn or nucleus gracilis\/cuneatus<\/span><\/div>\n    <div class=\"path-step\"><span class=\"order\">3rd ORDER<\/span>Thalamus<span class=\"loc\">VPL nucleus (contralateral)<\/span><\/div>\n    <div class=\"path-step\"><span class=\"order\">4th ORDER<\/span>Parietal Cortex<span class=\"loc\">Conscious perception<\/span><\/div>\n  <\/div>\n\n  <!-- SENSORY EXAM -->\n  <h3 class=\"subsection\">Sensory Examination Tests<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Pathway<\/th><th>Test<\/th><th>Tool<\/th><th>Notes<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td>Anterior ST<\/td><td>Light touch<\/td><td>Cotton swab<\/td><td>Screening only<\/td><\/tr>\n        <tr><td>Lateral ST<\/td><td>Temperature<\/td><td>Tip Therm \/ warm-cold tubes<\/td><td>Test first before pain<\/td><\/tr>\n        <tr><td>Lateral ST<\/td><td>Pain<\/td><td>Pinwheel<\/td><td>3 successive pricks; don't test palms\/soles; test dorsum of hand<\/td><\/tr>\n        <tr><td>DCML<\/td><td>Vibration sense<\/td><td>126 Hz tuning fork<\/td><td>Apply proximal to nail bed; if impaired → ulnar styloid \/ medial malleolus<\/td><\/tr>\n        <tr><td>DCML<\/td><td>Position sense<\/td><td>4th digit testing<\/td><td>5 trials; 3\/5 = mild; 0-2\/5 = severe<\/td><\/tr>\n        <tr><td>DCML<\/td><td>Romberg's test<\/td><td>—<\/td><td>Sways with eyes OPEN = Ataxia (cerebellar); Sways only with eyes CLOSED = Proprioception loss<\/td><\/tr>\n        <tr><td>DCML<\/td><td>2-point discrimination<\/td><td>2-pt device<\/td><td>Fingers: 2-4mm; Dorsum hand: 2-30mm; Palm: 8-12mm<\/td><\/tr>\n        <tr><td>Parietal lobe<\/td><td>Stereognosis<\/td><td>Common objects (keys, pen)<\/td><td>Ability to identify 3D objects by touch alone<\/td><\/tr>\n        <tr><td>Parietal lobe<\/td><td>Graphagnosis<\/td><td>Pen on skin<\/td><td>Identify numbers\/letters drawn on hand<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- LOCALIZATION PATTERNS -->\n  <h3 class=\"subsection\">Pattern of Sensory Loss → Localization <span class=\"tag red\">High Yield<\/span><\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Pattern<\/th><th>Suggests<\/th><th>Classic Example<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td>Localized (hand\/wrist)<\/td><td>Peripheral nerve (mononeuropathy)<\/td><td>Carpal tunnel syndrome (median n.)<\/td><\/tr>\n        <tr><td>Symmetric distal \"glove &amp; stocking\"<\/td><td>Polyneuropathy<\/td><td>Diabetic neuropathy<\/td><\/tr>\n        <tr><td>Dermatomal (one root)<\/td><td>Radiculopathy<\/td><td>L5 disc herniation<\/td><\/tr>\n        <tr><td>Asymmetric \/ multifocal<\/td><td>Mononeuritis multiplex<\/td><td>SLE, Sjogren's vasculitis<\/td><\/tr>\n        <tr><td>Hemisensory (half body)<\/td><td>Contralateral hemisphere \/ thalamus \/ brainstem \/ cord<\/td><td>Thalamic stroke<\/td><\/tr>\n        <tr><td>Bilateral lower extremities only<\/td><td>Thoracic or lumbar cord \/ polyneuropathy<\/td><td>Thoracic myelopathy<\/td><\/tr>\n        <tr><td>All four limbs<\/td><td>Cervical cord \/ brainstem \/ polyneuropathy<\/td><td>Cervical myelopathy, GBS<\/td><\/tr>\n        <tr><td>Entire limb (sudden)<\/td><td>Central (stroke)<\/td><td>MCA territory infarct<\/td><\/tr>\n        <tr class=\"hi-row\"><td><strong>Crossed deficit<\/strong> (ipsilateral face + contralateral body)<\/td><td><strong>BRAINSTEM<\/strong><\/td><td>Wallenberg syndrome<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- SPINAL CORD PATTERNS -->\n  <h3 class=\"subsection\">Special Spinal Cord Patterns <span class=\"tag red\">Must Know<\/span><\/h3>\n  <div class=\"grid-2\">\n    <div class=\"card\">\n      <div class=\"card-title\" style=\"color:var(--accent1);\">🔀 Brown-Séquard Syndrome<\/div>\n      <p style=\"font-size:0.85rem;margin-bottom:10px;\">Unilateral cord hemisection<\/p>\n      <ul style=\"font-size:0.86rem;\">\n        <li><strong>IPSILATERAL:<\/strong> Motor weakness + DCML loss (proprioception, vibration)<\/li>\n        <li><strong>CONTRALATERAL:<\/strong> Pain &amp; temperature loss (spinothalamic)<\/li>\n        <li>At the lesion level: Complete ipsilateral sensory deficit<\/li>\n      <\/ul>\n      <div class=\"alert alert-warn\" style=\"margin-top:10px;\">\n        <strong>Remember:<\/strong> DCML crosses in medulla → ipsilateral. ST crosses 1-2 levels above in cord → contralateral.\n      <\/div>\n    <\/div>\n    <div class=\"card\">\n      <div class=\"card-title\" style=\"color:var(--accent4);\">💧 Syringomyelia (Central Cord)<\/div>\n      <p style=\"font-size:0.85rem;margin-bottom:10px;\">\"Suspended\" or \"cape\" pattern — classic for syrinx<\/p>\n      <ul style=\"font-size:0.86rem;\">\n        <li><strong>LOST:<\/strong> Pain &amp; temperature bilaterally at the lesion level<\/li>\n        <li><strong>SPARED:<\/strong> DCML (vibration &amp; proprioception)<\/li>\n        <li>Affects decussating ST fibers near central canal<\/li>\n        <li>Usually from trauma or Chiari malformation<\/li>\n      <\/ul>\n      <div class=\"alert alert-info\" style=\"margin-top:10px;\">\n        <strong>Sacral sparing:<\/strong> Intramedullary lesion → upper extremities affected first (medial somatotopy)\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <!-- ASSOCIATED LESION SIGNS -->\n  <h3 class=\"subsection\">Associated Signs by Level<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Level<\/th><th>Sensory Pattern<\/th><th>Associated Features<\/th><th>Key Diseases<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Cerebral cortex (parietal)<\/strong><\/td><td>Contralateral hemisensory<\/td><td>Gerstmann syndrome (dominant angular gyrus), aphasia, ACA\/MCA\/PCA territory<\/td><td>Ischemic\/hemorrhagic stroke, MS (Dawson's fingers)<\/td><\/tr>\n        <tr><td><strong>Internal capsule<\/strong><\/td><td>Contralateral face+arm+leg<\/td><td>Dense hemiplegia (fibers packed), motor + sensory<\/td><td>Lacunar infarct (lenticulostriate aa.), hemorrhage<\/td><\/tr>\n        <tr><td><strong>Thalamus<\/strong><\/td><td>Contralateral half body<\/td><td>Thalamic pain (Dejerine-Roussy), cognitive dysfunction, ↓LOC (ARAS)<\/td><td>Small vessel disease, cardioembolism, hemorrhage<\/td><\/tr>\n        <tr class=\"hi-row\"><td><strong>Brainstem<\/strong><\/td><td><strong>CROSSED deficits<\/strong><\/td><td>4 Ds: Diplopia, Dysphagia, Dysarthria, Dizziness; CN ipsilateral + tracts contralateral<\/td><td>Wallenberg (PICA), MS, small vessel vasculitis<\/td><\/tr>\n        <tr><td><strong>Spinal cord<\/strong><\/td><td>Sensory level below lesion<\/td><td>Bladder\/bowel dysfunction in bilateral lesions<\/td><td>MS, B12 deficiency, spondylosis, syrinx<\/td><\/tr>\n        <tr><td><strong>Nerve root<\/strong><\/td><td>Dermatomal distribution<\/td><td>Shooting\/radiating pain, neck\/back pain<\/td><td>Disc herniation, spondylosis<\/td><\/tr>\n        <tr><td><strong>Peripheral nerve<\/strong><\/td><td>Glove &amp; stocking (distal)<\/td><td>Reduced distal reflexes, ± motor<\/td><td>DM neuropathy, GBS, CIDP<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- WORK-UP -->\n  <h3 class=\"subsection\">Diagnostic Work-up<\/h3>\n  <div class=\"grid-3\">\n    <div class=\"card\">\n      <div class=\"card-title\">🧲 Imaging<\/div>\n      <ul><li>CT \/ MRI brain<\/li><li>MRI spine \/ plexus<\/li><\/ul>\n    <\/div>\n    <div class=\"card\">\n      <div class=\"card-title\">🧪 Labs<\/div>\n      <ul><li>Vitamin B12 levels<\/li><li>Heavy metal screen<\/li><li>Glucose, HbA1c<\/li><li>Autoimmune panel<\/li><\/ul>\n    <\/div>\n    <div class=\"card\">\n      <div class=\"card-title\">⚡ Electrophysiology<\/div>\n      <ul><li><strong>EMG<\/strong> — tests muscle (fasciculations, fibrillations, MUPs)<\/li><li><strong>NCV<\/strong> — tests electrical flow (latency, amplitude, velocity)<\/li><li><strong>LP<\/strong> — albuminocytologic dissociation in AIDP<\/li><\/ul>\n    <\/div>\n  <\/div>\n<\/div>\n\n<!-- ============================================================ -->\n<!-- TAB 2: UMN WEAKNESS -->\n<!-- ============================================================ -->\n<div id=\"s02\" class=\"tab-content\">\n  <h2 class=\"section-title\">Clinical Approach to Motor Weakness — UMN<\/h2>\n  <p class=\"section-subtitle\">Corticospinal tract · Extrapyramidal system · UMN vs LMN · Stroke localization<\/p>\n\n  <!-- APPROACH -->\n  <h3 class=\"subsection\">Approach to Weakness<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Approach<\/th><th>Key Questions<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Parts Involved<\/strong><\/td><td>Face? Arm? Leg? — guides localization<\/td><\/tr>\n        <tr><td><strong>Mode of Onset<\/strong><\/td><td>Acute → Vascular | Subacute → Inflammatory\/demyelinating | Chronic → Degenerative\/neoplastic<\/td><\/tr>\n        <tr><td><strong>Duration &amp; Progression<\/strong><\/td><td>ALS: Progressive weakness → atrophy → dysphagia → respiratory failure → death<\/td><\/tr>\n        <tr><td><strong>Symmetry<\/strong><\/td><td>UMN = NOT isolated (involves multiple muscle groups)<\/td><\/tr>\n        <tr><td><strong>UMN vs LMN<\/strong><\/td><td>Spasticity\/hyperreflexia vs flaccidity\/hyporeflexia<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <div class=\"mnemonic\">\n    <div class=\"mnemonic-label\">⭐ Differential Diagnosis for Acute Focal Deficit<\/div>\n    <div class=\"mnemonic-text\">VITAMINS + DD<\/div>\n    <div class=\"mnemonic-expand\">Vascular · Infection · Trauma · Autoimmune · Metabolic · Idiopathic\/Iatrogenic · Nutritional · Seizure + Degenerative + Demyelinating<\/div>\n  <\/div>\n\n  <!-- CORTICOSPINAL TRACT -->\n  <h3 class=\"subsection\">Corticospinal Tract (Direct Pathway)<\/h3>\n  <div class=\"alert alert-info\">\n    <span class=\"label\">Course<\/span>\n    Precentral gyrus (BA4\/6) → Corona Radiata → Internal Capsule (posterior limb) → Crus cerebri → Basis pontis → Pyramids of medulla → <strong>90% decussate<\/strong> (Lateral CST) + 10% stay ipsilateral (Anterior CST) → Anterior horn cells → NMJ → Muscle\n  <\/div>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>CST Division<\/th><th>%<\/th><th>Decussation<\/th><th>Controls<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Lateral CST<\/strong><\/td><td>90%<\/td><td>Pyramids (dorsal medulla)<\/td><td>Limbs and digits<\/td><\/tr>\n        <tr><td><strong>Anterior CST<\/strong><\/td><td>10%<\/td><td>At level of spinal nerve exit<\/td><td>Trunk, shoulder, neck<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- STROKE LOCALIZATION -->\n  <h3 class=\"subsection\">Stroke Localization by Motor Pattern <span class=\"tag red\">High Yield<\/span><\/h3>\n  <div class=\"grid-3\">\n    <div class=\"card\" style=\"border-top:4px solid var(--accent2);\">\n      <div class=\"card-title\">ACA Stroke<\/div>\n      <p style=\"font-size:0.88rem;\">More weakness on <strong>LEGS than arms<\/strong> (medial motor cortex)<\/p>\n    <\/div>\n    <div class=\"card\" style=\"border-top:4px solid var(--accent1);\">\n      <div class=\"card-title\">MCA Stroke<\/div>\n      <p style=\"font-size:0.88rem;\">More weakness on <strong>ARMS &amp; FACE than legs<\/strong> (lateral cortex\/homunculus)<\/p>\n    <\/div>\n    <div class=\"card\" style=\"border-top:4px solid var(--accent4);\">\n      <div class=\"card-title\">Internal Capsule Stroke<\/div>\n      <p style=\"font-size:0.88rem;\"><strong>Equal<\/strong> arm &amp; leg weakness — <strong>Dense hemiplegia<\/strong> (face + arm + leg); fibers are tightly packed<\/p>\n      <div class=\"alert alert-warn\" style=\"margin-top:8px; font-size:0.8rem;\">Lenticulostriate arteries (branches of M1 segment of MCA)<\/div>\n    <\/div>\n  <\/div>\n\n  <!-- STROKE SUPERLATIVES -->\n  <div class=\"alert alert-danger\">\n    <span class=\"label\">⭐ Stroke Superlatives — Board Favorite!<\/span>\n    <strong>Most common cause of acute hyperdensity on CT:<\/strong> Acute hemorrhage &nbsp;|&nbsp;\n    <strong>Most common location of hemorrhage:<\/strong> Basal ganglia &nbsp;|&nbsp;\n    <strong>Most common part of basal ganglia:<\/strong> Putamen\n  <\/div>\n\n  <!-- UMN vs LMN TABLE -->\n  <h3 class=\"subsection\">UMN vs LMN Syndrome <span class=\"tag red\">Must Memorize<\/span><\/h3>\n  <div class=\"compare-wrap\">\n    <div class=\"compare-col umn\">\n      <h3>🔴 UMN Syndrome<\/h3>\n      <ul>\n        <li><strong>Spastic paresis<\/strong> (clasp-knife)<\/li>\n        <li><strong>Hypertonia<\/strong><\/li>\n        <li><strong>Hyperreflexia<\/strong> (&gt;2+)<\/li>\n        <li><strong>Positive Babinski sign<\/strong><\/li>\n        <li>Absent superficial reflexes<\/li>\n        <li>No\/minimal atrophy (disuse only)<\/li>\n        <li>NO fasciculations<\/li>\n        <li>Normal muscle response to electric stimulation<\/li>\n      <\/ul>\n    <\/div>\n    <div class=\"compare-col lmn\">\n      <h3>🔵 LMN Syndrome<\/h3>\n      <ul>\n        <li><strong>Flaccid paralysis<\/strong><\/li>\n        <li><strong>Hypotonia<\/strong><\/li>\n        <li><strong>Hypo\/areflexia<\/strong> (&lt;2+)<\/li>\n        <li>Absent Babinski sign<\/li>\n        <li>Superficial reflexes present<\/li>\n        <li><strong>Severe atrophy<\/strong><\/li>\n        <li><strong>Fasciculations<\/strong> (can be present)<\/li>\n      <\/ul>\n    <\/div>\n  <\/div>\n\n  <!-- UMN SIGNS -->\n  <h3 class=\"subsection\">Corticospinal Tract (UMN) Signs<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Sign<\/th><th>Description<\/th><th>Key Point<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Spasticity<\/strong><\/td><td>Velocity-DEPENDENT resistance (clasp-knife)<\/td><td>Affects antigravity muscles; upper limb flexors, lower limb extensors<\/td><\/tr>\n        <tr><td><strong>Hyperreflexia<\/strong><\/td><td>Exaggerated DTRs (patellar, Achilles)<\/td><td>⭐ Key sign of UMN involvement<\/td><\/tr>\n        <tr class=\"hi-row\"><td><strong>Babinski Sign<\/strong><\/td><td>Extension of big toe + fanning of other toes on plantar stimulation<\/td><td>⭐ Classic UMN sign; normal in infants; use ↑ arrow in DTR diagram<\/td><\/tr>\n        <tr><td><strong>Hoffman's Sign<\/strong><\/td><td>Flick middle finger → thumb &amp; index flex<\/td><td>UMN in upper limbs; cervical myelopathy<\/td><\/tr>\n        <tr><td><strong>Chaddock's Sign<\/strong><\/td><td>Stroke lateral foot heel→malleolus → great toe extension<\/td><td>Alternative to Babinski (if difficult to elicit)<\/td><\/tr>\n        <tr><td><strong>Clonus<\/strong><\/td><td>Sustained rhythmic contractions on dorsiflexion of ankle<\/td><td>Seen in cervical myelopathy<\/td><\/tr>\n        <tr><td><strong>Lhermitte's Sign<\/strong><\/td><td>Neck flexion → electric shock down spine<\/td><td>Demyelination (MS), cervical myelopathy; NOT pathognomonic<\/td><\/tr>\n        <tr><td><strong>Loss of fine motor skills<\/strong><\/td><td>Difficulty writing, buttoning shirts<\/td><td>⭐ Most difficult-to-detect UMN weakness<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- SPASTICITY vs RIGIDITY -->\n  <h3 class=\"subsection\">Spasticity vs Rigidity<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Feature<\/th><th>Spasticity (UMN)<\/th><th>Rigidity (Extrapyramidal)<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td>Velocity<\/td><td>✅ Velocity-DEPENDENT<\/td><td>❌ Velocity-INDEPENDENT<\/td><\/tr>\n        <tr><td>Character<\/td><td>\"Clasp-knife\" — initial stiffness then release<\/td><td>\"Lead-pipe\" (constant) or \"Cogwheel\" (with tremor)<\/td><\/tr>\n        <tr><td>Muscles affected<\/td><td>Antigravity muscles (quadriceps, soleus, extensors)<\/td><td>Flexors AND extensors equally<\/td><\/tr>\n        <tr><td>Associated with<\/td><td>Stroke, cerebral palsy<\/td><td>Parkinson's disease (extrapyramidal)<\/td><\/tr>\n        <tr><td>Mnemonic<\/td><td>Swiss-knife = Spasticity<\/td><td>US HiLand Beef is Extra Rigid<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- MANUAL MUSCLE TESTING -->\n  <h3 class=\"subsection\">Manual Muscle Testing<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Grade<\/th><th>Description<\/th><th>Interpretation<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><span class=\"badge badge-red\">0\/5<\/span><\/td><td>No muscular contraction detected<\/td><td>Plegia (−plegia)<\/td><\/tr>\n        <tr><td><span class=\"badge badge-red\">1\/5<\/span><\/td><td>Barely detectable flicker of contraction<\/td><td>Plegia<\/td><\/tr>\n        <tr><td><span class=\"badge badge-orange\">2\/5<\/span><\/td><td>Active movement with gravity eliminated<\/td><td>Paresis<\/td><\/tr>\n        <tr><td><span class=\"badge badge-orange\">3\/5<\/span><\/td><td>Active movement AGAINST gravity<\/td><td>Paresis<\/td><\/tr>\n        <tr><td><span class=\"badge badge-blue\">4\/5<\/span><\/td><td>Active movement against gravity + some resistance<\/td><td>Paresis<\/td><\/tr>\n        <tr><td><span class=\"badge badge-green\">5\/5<\/span><\/td><td>Full strength against full resistance<\/td><td>Normal<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- FACIAL PALSY -->\n  <h3 class=\"subsection\">Central vs Peripheral Facial Palsy <span class=\"tag red\">High Yield<\/span><\/h3>\n  <div class=\"grid-2\">\n    <div class=\"card\" style=\"border-left:4px solid var(--accent1);\">\n      <div class=\"card-title\">🔴 Central Facial Palsy (UMN — Stroke)<\/div>\n      <ul style=\"font-size:0.88rem;\">\n        <li><strong>Only lower 2\/3 of face affected<\/strong><\/li>\n        <li><strong>Forehead SPARED<\/strong> (bilateral cortical innervation)<\/li>\n        <li>Weakness at nasolabial fold only<\/li>\n        <li>Contralateral to lesion<\/li>\n        <li>Associated arm\/leg weakness<\/li>\n      <\/ul>\n    <\/div>\n    <div class=\"card\" style=\"border-left:4px solid var(--accent2);\">\n      <div class=\"card-title\">🔵 Peripheral Facial Palsy (LMN — Bell's Palsy)<\/div>\n      <ul style=\"font-size:0.88rem;\">\n        <li><strong>Entire half of face affected (forehead NOT spared)<\/strong><\/li>\n        <li>Cannot close eye (Bell's palsy hallmark)<\/li>\n        <li>Arm and leg NORMAL<\/li>\n        <li>Most common ER mimicker!<\/li>\n      <\/ul>\n      <div class=\"alert alert-warn\" style=\"margin-top:8px;font-size:0.82rem;\">If arm\/leg is 5\/5 but face asymmetric → think Bell's Palsy, NOT stroke<\/div>\n    <\/div>\n  <\/div>\n\n  <!-- EXTRAPYRAMIDAL -->\n  <h3 class=\"subsection\">Indirect (Extrapyramidal) Tracts<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Tract<\/th><th>Origin<\/th><th>Decussation<\/th><th>Function<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Rubrospinal<\/strong><\/td><td>Red nucleus (midbrain tegmentum)<\/td><td>Midbrain (ventral tegmental)<\/td><td>Skilled voluntary movements of distal limb muscles; flexor facilitation; inhibits extensor tone<\/td><\/tr>\n        <tr><td><strong>Reticulospinal (Pontine)<\/strong><\/td><td>Pontine reticular formation<\/td><td>Ipsilateral (medial RST)<\/td><td>Leg extensors; pattern movement (stepping); antigravity support<\/td><\/tr>\n        <tr><td><strong>Reticulospinal (Medullary)<\/strong><\/td><td>Medullary reticular formation<\/td><td>Bilateral (lateral RST)<\/td><td>Inhibits cranial\/spinal motor neurons; inhibits antigravity tone<\/td><\/tr>\n        <tr><td><strong>Vestibulospinal (Lateral)<\/strong><\/td><td>Lateral vestibular nucleus<\/td><td>Ipsilateral<\/td><td>Facilitates antigravity muscles; postural equilibrium (body\/legs)<\/td><\/tr>\n        <tr><td><strong>Vestibulospinal (Medial)<\/strong><\/td><td>Medial vestibular nucleus<\/td><td>Bilateral<\/td><td>Adjusts neck\/upper limb posture; dizziness if lesion<\/td><\/tr>\n        <tr><td><strong>Tectospinal<\/strong><\/td><td>Superior colliculus<\/td><td>Contralateral (dorsal mesencephalic)<\/td><td>Coordinates head &amp; eye movements in response to visual\/auditory stimuli<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <div class=\"alert alert-danger\">\n    <span class=\"label\">⭐ Benedikt's Syndrome — Tegmentum of Midbrain<\/span>\n    Structures: CN III + Red nucleus + Corticospinal tract + Superior cerebellar peduncle after decussation<br>\n    Signs: <strong>Ipsilateral CN III palsy<\/strong> + <strong>Contralateral ataxia, tremor, hemiplegia<\/strong>\n  <\/div>\n\n  <!-- CERVICAL MYELOPATHY SIGNS -->\n  <h3 class=\"subsection\">Cervical Myelopathy Signs<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Test<\/th><th>How to Elicit<\/th><th>Positive Sign<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td>Babinski<\/td><td>Stroke lateral foot → medial<\/td><td>Great toe dorsiflexion + toe fanning<\/td><\/tr>\n        <tr><td>Hoffman's<\/td><td>Flick nail of middle\/ring finger<\/td><td>Thumb + index finger flex<\/td><\/tr>\n        <tr><td>Lhermitte's<\/td><td>Flex neck while hip-flexed in long sitting<\/td><td>Electric shock sensation down spine<\/td><\/tr>\n        <tr><td>Clonus<\/td><td>Sudden ankle dorsiflexion<\/td><td>Sustained back-and-forth foot movements<\/td><\/tr>\n        <tr><td>Finger Escape Sign<\/td><td>Extend + adduct fingers × 1 min<\/td><td>5th digit drifts into abduction<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n<\/div>\n\n<!-- ============================================================ -->\n<!-- TAB 3: LMN WEAKNESS -->\n<!-- ============================================================ -->\n<div id=\"s03\" class=\"tab-content\">\n  <h2 class=\"section-title\">Clinical Approach to Motor Weakness — LMN<\/h2>\n  <p class=\"section-subtitle\">Motor unit · PNS localization · Nerve roots · Plexus · NMJ · Muscle<\/p>\n\n  <!-- MOTOR UNIT LEVELS -->\n  <h3 class=\"subsection\">The Motor Unit — 5 Levels of Localization<\/h3>\n  <div class=\"grid-3\">\n    <div class=\"card\" style=\"border-top:4px solid var(--accent1);\">\n      <div class=\"card-title\">① Anterior Horn Cell (AHC)<\/div>\n      <ul style=\"font-size:0.85rem;\">\n        <li>Prototype: <strong>ALS<\/strong><\/li>\n        <li>UMN + LMN signs<\/li>\n        <li>Fasciculations, atrophy<\/li>\n        <li>NO sensory symptoms<\/li>\n      <\/ul>\n    <\/div>\n    <div class=\"card\" style=\"border-top:4px solid var(--accent2);\">\n      <div class=\"card-title\">② Nerve Root (Radiculopathy)<\/div>\n      <ul style=\"font-size:0.85rem;\">\n        <li>Dermatomal distribution<\/li>\n        <li><strong>PAIN<\/strong> is hallmark<\/li>\n        <li>\"Shooting pain\" down extremity<\/li>\n        <li>Sensory + motor in root territory<\/li>\n      <\/ul>\n    <\/div>\n    <div class=\"card\" style=\"border-top:4px solid var(--accent3);\">\n      <div class=\"card-title\">③ Peripheral Nerve<\/div>\n      <ul style=\"font-size:0.85rem;\">\n        <li>Glove &amp; stocking pattern (PN)<\/li>\n        <li>Distal sensory loss<\/li>\n        <li>Reduced distal reflexes<\/li>\n      <\/ul>\n    <\/div>\n    <div class=\"card\" style=\"border-top:4px solid var(--accent4);\">\n      <div class=\"card-title\">④ NMJ<\/div>\n      <ul style=\"font-size:0.85rem;\">\n        <li><strong>FATIGUE<\/strong> is hallmark<\/li>\n        <li>NO sensory symptoms<\/li>\n        <li>Bulbar (ptosis, diplopia)<\/li>\n        <li>MG vs LEMS<\/li>\n      <\/ul>\n    <\/div>\n    <div class=\"card\" style=\"border-top:4px solid #e07b00;\">\n      <div class=\"card-title\">⑤ Muscle<\/div>\n      <ul style=\"font-size:0.85rem;\">\n        <li><strong>Proximal<\/strong> symmetric weakness<\/li>\n        <li>NO sensory symptoms<\/li>\n        <li>Elevated CK<\/li>\n      <\/ul>\n    <\/div>\n  <\/div>\n\n  <!-- BASIC SPINE EXAM -->\n  <h3 class=\"subsection\">Basic Spine Exam <span class=\"tag red\">Must Memorize<\/span><\/h3>\n  <div class=\"nerve-duo\">\n    <div>\n      <div class=\"tbl-wrap\">\n        <table>\n          <thead><tr><th>Nerve<\/th><th>Muscle<\/th><th>Action<\/th><\/tr><\/thead>\n          <tbody>\n            <tr><td class=\"reflex-nerve\">C5<\/td><td>Deltoid<\/td><td>Shoulder abduction<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">C6<\/td><td>Biceps<\/td><td>Elbow flexion<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">C7<\/td><td>Extensor Carpi<\/td><td>Wrist extension<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">C8<\/td><td>Finger flexors<\/td><td>Grip<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">T1<\/td><td>Finger extrinsics<\/td><td>Finger abduction<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">L2<\/td><td>Iliopsoas<\/td><td>Hip flexion<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">L3<\/td><td>Quadriceps<\/td><td>Knee extension<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">L4<\/td><td>Tibialis anterior<\/td><td>Ankle dorsiflexion<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">L5<\/td><td>Extensor hallucis<\/td><td>1st toe extension<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">S1<\/td><td>Gastrocnemius<\/td><td>Ankle plantarflexion<\/td><\/tr>\n          <\/tbody>\n        <\/table>\n      <\/div>\n    <\/div>\n    <div>\n      <p style=\"font-size:0.85rem;font-weight:700;margin-bottom:8px;\">Sensory Levels<\/p>\n      <div class=\"tbl-wrap\">\n        <table>\n          <thead><tr><th>Nerve<\/th><th>Territory<\/th><\/tr><\/thead>\n          <tbody>\n            <tr><td class=\"reflex-nerve\">C6<\/td><td>1st &amp; 2nd fingers<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">C7<\/td><td>Middle finger<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">C8<\/td><td>4th &amp; 5th fingers<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">T4<\/td><td>Nipples<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">T10<\/td><td>Umbilicus<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">L3<\/td><td>Knee<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">L4<\/td><td>Medial dorsal foot<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">L5<\/td><td>Lateral dorsal foot<\/td><\/tr>\n            <tr><td class=\"reflex-nerve\">S1<\/td><td>Plantar foot<\/td><\/tr>\n          <\/tbody>\n        <\/table>\n      <\/div>\n      <p style=\"font-size:0.85rem;font-weight:700;margin:12px 0 8px;\">Deep Tendon Reflexes<\/p>\n      <div class=\"reflex-map\">\n        <div class=\"reflex-item\"><span class=\"reflex-nerve\">C5-C6<\/span><span class=\"reflex-muscle\">Biceps<\/span><\/div>\n        <div class=\"reflex-item\"><span class=\"reflex-nerve\">C7-C8<\/span><span class=\"reflex-muscle\">Triceps<\/span><\/div>\n        <div class=\"reflex-item\"><span class=\"reflex-nerve\">L3-L4<\/span><span class=\"reflex-muscle\">Patellar<\/span><\/div>\n        <div class=\"reflex-item\"><span class=\"reflex-nerve\">S1-S2<\/span><span class=\"reflex-muscle\">Achilles<\/span><\/div>\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <!-- REFLEXIA TABLE -->\n  <h3 class=\"subsection\">Hypo\/Hyperreflexia Interpretation<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Type<\/th><th>Hyporeflexia<\/th><th>Hyperreflexia<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Symmetric<\/strong><\/td><td>Non-pathologic; metabolic DSE or peripheral neuropathy<\/td><td>Non-pathologic; hypocalcemia, hyperthyroidism<\/td><\/tr>\n        <tr class=\"hi-row\"><td><strong>Unilateral (Asymmetric)<\/strong><\/td><td><strong>LMN process<\/strong><\/td><td><strong>UMN process<\/strong><\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n  <div class=\"alert alert-danger\">Asymmetric reflexes are ALWAYS pathologic!<\/div>\n\n  <!-- DISC HERNIATION -->\n  <h3 class=\"subsection\">Disc Herniation & Radiculopathy<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Disc Level<\/th><th>Root Compressed<\/th><th>Motor Deficit<\/th><th>Sensory Loss<\/th><th>Reflex Lost<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td>C4-C5<\/td><td>C5<\/td><td>Deltoid (shoulder abduction)<\/td><td>Lateral shoulder\/arm<\/td><td>Biceps<\/td><\/tr>\n        <tr><td>C5-C6<\/td><td>C6<\/td><td>Biceps (elbow flexion)<\/td><td>1st &amp; 2nd fingers<\/td><td>Biceps, brachioradialis<\/td><\/tr>\n        <tr><td>C6-C7<\/td><td>C7<\/td><td>Triceps, wrist extension<\/td><td>Middle finger<\/td><td>Triceps<\/td><\/tr>\n        <tr><td>L4-L5<\/td><td>L5<\/td><td>Foot dorsiflexion, big toe ext.<\/td><td>Lateral dorsum foot<\/td><td>(minimal)<\/td><\/tr>\n        <tr class=\"hi-row\"><td>L5-S1<\/td><td>S1 (most common)<\/td><td>Ankle plantarflexion<\/td><td>Plantar foot, lateral calf<\/td><td><strong>Achilles<\/strong><\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n  <div class=\"alert alert-warn\">Areas of greatest instability: <strong>C5-C7<\/strong> and <strong>L4-S1<\/strong>. Note: The nerve root exits BELOW the same-named vertebra (C6 exits below C5).<\/div>\n\n  <!-- FOCAL NEUROPATHIES -->\n  <h3 class=\"subsection\">Common Focal Neuropathies <span class=\"tag red\">High Yield<\/span><\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Nerve<\/th><th>Syndrome<\/th><th>Motor<\/th><th>Sensory<\/th><th>Key Sign<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Median<\/strong><\/td><td>Carpal tunnel syndrome<\/td><td>Thenar weakness (thumb opposition)<\/td><td>Palmar aspect 1st-3rd + lateral half 4th digit<\/td><td>Tinel's sign at wrist (tap = tingling)<\/td><\/tr>\n        <tr><td><strong>Ulnar<\/strong><\/td><td>Cubital tunnel \/ Guyon's canal<\/td><td>Interossei, hypothenar, 3rd &amp; 4th lumbricals<\/td><td>Medial palm + 4th-5th digits (palmar &amp; dorsal)<\/td><td>Claw hand (4th &amp; 5th)<\/td><\/tr>\n        <tr><td><strong>Radial<\/strong><\/td><td>Radial nerve palsy (Saturday night palsy)<\/td><td>All extensors of arm &amp; hand<\/td><td>Dorsal aspect 1st to ½ 3rd digit<\/td><td><strong>Wrist drop<\/strong><\/td><\/tr>\n        <tr><td><strong>Peroneal<\/strong><\/td><td>Fibular head compression<\/td><td>Dorsiflexion, eversion<\/td><td>Lateral leg, dorsal foot<\/td><td><strong>Foot drop<\/strong><\/td><\/tr>\n        <tr><td><strong>Femoral<\/strong><\/td><td>—<\/td><td>Quadriceps (knee extension)<\/td><td>Anterior thigh, medial lower leg<\/td><td>Loss of patellar reflex<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- NMJ -->\n  <h3 class=\"subsection\">NMJ Diseases: MG vs LEMS<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Feature<\/th><th>Myasthenia Gravis (MG)<\/th><th>Lambert-Eaton (LEMS)<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td>Mechanism<\/td><td>Post-synaptic (anti-AChR antibodies)<\/td><td>Pre-synaptic (anti-VGCC antibodies)<\/td><\/tr>\n        <tr><td>Effect of exercise<\/td><td>Weakness WORSENS with use<\/td><td>Strength BRIEFLY IMPROVES with use<\/td><\/tr>\n        <tr><td>Reflexes<\/td><td>Normal<\/td><td>Hypo\/areflexic<\/td><\/tr>\n        <tr><td>Sensory<\/td><td>NONE — preserved<\/td><td>NONE — preserved<\/td><\/tr>\n        <tr><td>Cranial nerve involvement<\/td><td>Ptosis (CN III), diplopia, dysphagia<\/td><td>Less common<\/td><\/tr>\n        <tr><td>Association<\/td><td>Thymoma<\/td><td>Small cell lung cancer<\/td><\/tr>\n        <tr><td>Testing<\/td><td>Repetitive nerve stimulation (decrement)<\/td><td>Repetitive nerve stimulation (increment)<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- BRACHIAL PLEXUS -->\n  <h3 class=\"subsection\">Brachial Plexus Lesions<\/h3>\n  <div class=\"grid-2\">\n    <div class=\"card\" style=\"border-left:4px solid var(--accent1);\">\n      <div class=\"card-title\">Upper Trunk (C5-C6) → Erb's Palsy<\/div>\n      <ul style=\"font-size:0.87rem;\">\n        <li>Supraspinatus, infraspinatus, deltoid, biceps, supinator weakness<\/li>\n        <li><strong>Waiter's tip posture<\/strong> (arm hangs, medially rotated, pronated)<\/li>\n        <li>Usually from shoulder dystocia at birth<\/li>\n      <\/ul>\n    <\/div>\n    <div class=\"card\" style=\"border-left:4px solid var(--accent4);\">\n      <div class=\"card-title\">Lower Trunk (C7-C8-T1) → Klumpke's Palsy<\/div>\n      <ul style=\"font-size:0.87rem;\">\n        <li>Intrinsic hand muscles + finger flexors weak<\/li>\n        <li>T1 involvement → <strong>Horner's syndrome<\/strong> (ptosis, miosis, anhidrosis)<\/li>\n        <li>Complete congenital brachial plexus palsy<\/li>\n      <\/ul>\n    <\/div>\n  <\/div>\n\n  <!-- COMPREHENSIVE LOCALIZATION TABLE -->\n  <h3 class=\"subsection\">Summary Localization by Level <span class=\"tag red\">Board Favorite<\/span><\/h3>\n  <div class=\"tbl-wrap loc-table\">\n    <table>\n      <thead><tr><th>Feature<\/th><th>AHC<\/th><th>Root<\/th><th>Plexus\/PN<\/th><th>NMJ<\/th><th>Muscle<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Key feature<\/strong><\/td><td>UMN+LMN signs<\/td><td>Pain (shooting)<\/td><td>Distal sensory loss<\/td><td>Fatigue<\/td><td>Proximal weakness<\/td><\/tr>\n        <tr><td><strong>Sensory symptoms<\/strong><\/td><td>None<\/td><td>Yes (dermatomal)<\/td><td>Yes (glove-stocking)<\/td><td>None<\/td><td>None<\/td><\/tr>\n        <tr><td><strong>Weakness distribution<\/strong><\/td><td>Asymmetric<\/td><td>Asymmetric<\/td><td>Distal symmetric (PN)<\/td><td>EOM, bulbar<\/td><td>Proximal symmetric<\/td><\/tr>\n        <tr><td><strong>Reflexes<\/strong><\/td><td>+++ (UMN) \/ absent (LMN)<\/td><td>Asymmetric loss<\/td><td>Early loss<\/td><td>Normal (MG) \/ ↓ (LEMS)<\/td><td>Late loss; NEVER hyper<\/td><\/tr>\n        <tr><td><strong>Atrophy<\/strong><\/td><td>Early<\/td><td>Dermatomal<\/td><td>Glove-stocking<\/td><td>None (unless severe)<\/td><td>Late \/ pseudohypertrophy<\/td><\/tr>\n        <tr><td><strong>Fasciculations<\/strong><\/td><td>YES<\/td><td>Yes<\/td><td>Yes<\/td><td>No<\/td><td>No<\/td><\/tr>\n        <tr><td><strong>Prototype disease<\/strong><\/td><td>ALS<\/td><td>Sciatica<\/td><td>DM neuropathy<\/td><td>MG<\/td><td>Polymyositis<\/td><\/tr>\n        <tr><td><strong>Testing<\/strong><\/td><td>EMG-NCV<\/td><td>EMG-NCV<\/td><td>EMG-NCV<\/td><td>RNS<\/td><td>CPK, EMG<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n<\/div>\n\n<!-- ============================================================ -->\n<!-- TAB 4: ALTERED SENSORIUM -->\n<!-- ============================================================ -->\n<div id=\"s04\" class=\"tab-content\">\n  <h2 class=\"section-title\">Clinical Approach to Alteration in Sensorium<\/h2>\n  <p class=\"section-subtitle\">Coma exam · SPERM · GCS · Structural vs metabolic · Approach to coma<\/p>\n\n  <!-- LEVELS OF CONSCIOUSNESS -->\n  <h3 class=\"subsection\">Levels of Consciousness <span class=\"tag red\">Must Know<\/span><\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Level<\/th><th>Stimulus Needed<\/th><th>Response<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><span class=\"badge badge-green\">Alert<\/span><\/td><td>None (voice)<\/td><td>Eyes open spontaneously; oriented to 3 spheres; follows commands<\/td><\/tr>\n        <tr><td><span class=\"badge badge-blue\">Drowsy (Somnolent)<\/span><\/td><td>Voice<\/td><td>Opens eyes; follows simple commands but drifts off; incoherent mumbles<\/td><\/tr>\n        <tr><td><span class=\"badge badge-orange\">Lethargic<\/span><\/td><td>Light tapping<\/td><td>Opens eyes; follows commands but drifts away; does ~1\/3 commands<\/td><\/tr>\n        <tr><td><span class=\"badge badge-orange\">Obtunded<\/span><\/td><td>Vigorous stimulus (shaking)<\/td><td>Opens eyes; does NOT follow commands; drifts away quickly<\/td><\/tr>\n        <tr><td><span class=\"badge badge-red\">Stuporous<\/span><\/td><td>Loud voice + vigorous stimulus<\/td><td>NO eye opening; slight movement to pain<\/td><\/tr>\n        <tr><td><span class=\"badge badge-red\">Comatose<\/span><\/td><td>Any stimulus including pain<\/td><td>NO response<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- SPERM -->\n  <h3 class=\"subsection\">SPERM Quick Coma Exam <span class=\"tag red\">Must Memorize<\/span><\/h3>\n  <div class=\"sperm-grid\">\n    <div class=\"sperm-item\"><span class=\"sperm-letter\">S<\/span><div class=\"sperm-word\">Sensorium<\/div><div class=\"sperm-detail\">Level of consciousness<\/div><\/div>\n    <div class=\"sperm-item\"><span class=\"sperm-letter\">P<\/span><div class=\"sperm-word\">Pupils<\/div><div class=\"sperm-detail\">Size, reactivity, symmetry<\/div><\/div>\n    <div class=\"sperm-item\"><span class=\"sperm-letter\">E<\/span><div class=\"sperm-word\">EOM<\/div><div class=\"sperm-detail\">Extraocular movements<\/div><\/div>\n    <div class=\"sperm-item\"><span class=\"sperm-letter\">R<\/span><div class=\"sperm-word\">Respiration<\/div><div class=\"sperm-detail\">Pattern localizes lesion<\/div><\/div>\n    <div class=\"sperm-item\"><span class=\"sperm-letter\">M<\/span><div class=\"sperm-word\">Motor<\/div><div class=\"sperm-detail\">Tone, posturing, reflexes<\/div><\/div>\n  <\/div>\n\n  <!-- STRUCTURAL vs METABOLIC -->\n  <h3 class=\"subsection\">Structural vs Metabolic Coma <span class=\"tag red\">High Yield<\/span><\/h3>\n  <div class=\"compare-wrap\">\n    <div class=\"compare-col umn\">\n      <h3>🏗 STRUCTURAL<\/h3>\n      <ul>\n        <li><strong>Asymmetry<\/strong><\/li>\n        <li>Abnormal reflexes<\/li>\n        <li>FOCALITY<\/li>\n        <li>Examples: ICH, contusion, infarct, tumor, seizure, ↑ICP<\/li>\n      <\/ul>\n    <\/div>\n    <div class=\"compare-col lmn\">\n      <h3>⚗ METABOLIC<\/h3>\n      <ul>\n        <li><strong>Symmetry<\/strong><\/li>\n        <li>Normal reflexes<\/li>\n        <li>NON-focal<\/li>\n        <li>Examples: Hypoxia, hypoglycemia, hypotension, drugs, CO₂ retention, osmolar changes<\/li>\n      <\/ul>\n    <\/div>\n  <\/div>\n  <div class=\"alert alert-warn\"><strong>Key rule:<\/strong> When doing neuro exam in coma → always look for signs of ASYMMETRY (suggests structural)<\/div>\n\n  <!-- PUPIL PATTERNS -->\n  <h3 class=\"subsection\">Pupillary Patterns by Lesion Location <span class=\"tag red\">High Yield<\/span><\/h3>\n  <div class=\"pupil-grid\">\n    <div class=\"pupil-card\">\n      <span class=\"pupil-emoji\">🔵🔵<\/span>\n      <div class=\"pupil-site\">Diencephalon \/ Metabolic<\/div>\n      <div class=\"pupil-desc\">Small, REACTIVE pupils<\/div>\n    <\/div>\n    <div class=\"pupil-card\" style=\"background:#fff0f0;\">\n      <span class=\"pupil-emoji\">🔴⚪<\/span>\n      <div class=\"pupil-site\">CN III (Oculomotor)<\/div>\n      <div class=\"pupil-desc\">Ipsilateral dilated fixed — most common cause of anisocoria<\/div>\n    <\/div>\n    <div class=\"pupil-card\" style=\"background:#fff3cd;\">\n      <span class=\"pupil-emoji\">⚫⚫<\/span>\n      <div class=\"pupil-site\">Midbrain<\/div>\n      <div class=\"pupil-desc\">Mid-dilated, FIXED (both SNS & PNS gone)<\/div>\n    <\/div>\n    <div class=\"pupil-card\" style=\"background:#f0f4ff;\">\n      <span class=\"pupil-emoji\">🟣🟣<\/span>\n      <div class=\"pupil-site\">Pons<\/div>\n      <div class=\"pupil-desc\">Pinpoint pupils (PNS intact)<\/div>\n    <\/div>\n    <div class=\"pupil-card\" style=\"background:#ffe8f0;\">\n      <span class=\"pupil-emoji\">🔴🔴<\/span>\n      <div class=\"pupil-site\">Pretectal<\/div>\n      <div class=\"pupil-desc\">Large, fixed; hippus (rhythmic dilation\/constriction)<\/div>\n    <\/div>\n    <div class=\"pupil-card\" style=\"background:#e8f5e9;\">\n      <span class=\"pupil-emoji\">💊💊<\/span>\n      <div class=\"pupil-site\">Opioids (Metabolic)<\/div>\n      <div class=\"pupil-desc\">Pinpoint REACTIVE (brainstem intact); preserved reflexes<\/div>\n    <\/div>\n  <\/div>\n  <div class=\"alert alert-danger\"><strong>Worst pupillary reaction:<\/strong> Mid-dilated NON-reactive (both SNS & PNS drives lost)<\/div>\n\n  <!-- RESPIRATORY PATTERNS -->\n  <h3 class=\"subsection\">Respiratory Patterns & Localization<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Pattern<\/th><th>Lesion<\/th><th>Description<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Cheyne-Stokes<\/strong><\/td><td>Cerebrum or Diencephalon<\/td><td>Waxing-waning hyperpnea alternating with apnea<\/td><\/tr>\n        <tr><td><strong>Central Neurogenic Hyperventilation<\/strong><\/td><td>Lower midbrain to upper pons<\/td><td>↑ Rate &amp; depth → respiratory alkalosis<\/td><\/tr>\n        <tr><td><strong>Apneustic<\/strong><\/td><td>Pons<\/td><td>Prolonged inspirations separated by brief expirations<\/td><\/tr>\n        <tr class=\"hi-row\"><td><strong>Cluster Breathing<\/strong><\/td><td>Lower pons<\/td><td>Groups of breaths with long apnea periods<\/td><\/tr>\n        <tr><td><strong>Ataxic Breathing<\/strong><\/td><td>Medulla<\/td><td>Highly irregular inspirations with long apneas<\/td><\/tr>\n        <tr><td><strong>Apnea<\/strong><\/td><td>Medulla<\/td><td>Cessation of breathing<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- POSTURING -->\n  <h3 class=\"subsection\">Posturing — Coma Localization <span class=\"tag red\">Must Know<\/span><\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Posture<\/th><th>Lesion Location<\/th><th>Description<\/th><th>Prognosis<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Hemiparesis<\/strong><\/td><td>Forebrain or Diencephalon<\/td><td>Lack of motor response one side; externally rotated foot<\/td><td>Better<\/td><\/tr>\n        <tr class=\"hi-row\"><td><strong>Decorticate<\/strong><\/td><td>Above red nucleus (Upper midbrain)<\/td><td>UPPER: Flexion | LOWER: Extension — \"C\" for cortex = curl arms in<\/td><td>Worse<\/td><\/tr>\n        <tr class=\"hi-row\"><td><strong>Decerebrate<\/strong><\/td><td>Below red nucleus (Upper pons)<\/td><td>ALL extremities EXTENDED — \"you're in trouble\"<\/td><td>Worst<\/td><\/tr>\n        <tr><td>Moves away from stimulus<\/td><td>Metabolic encephalopathy<\/td><td>Purposeful withdrawal = shallower coma<\/td><td>Better<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- GCS -->\n  <h3 class=\"subsection\">Glasgow Coma Scale <span class=\"tag red\">Memorize Scoring<\/span><\/h3>\n  <div class=\"gcs-wrap\">\n    <div class=\"gcs-block\">\n      <div class=\"gcs-header\">👁 Eye Opening (E) max 4<\/div>\n      <div class=\"gcs-rows\">\n        <div class=\"gcs-row\"><span>Spontaneous<\/span><span class=\"gcs-score\">4<\/span><\/div>\n        <div class=\"gcs-row\"><span>To voice\/call<\/span><span class=\"gcs-score\">3<\/span><\/div>\n        <div class=\"gcs-row\"><span>To pain<\/span><span class=\"gcs-score\">2<\/span><\/div>\n        <div class=\"gcs-row\"><span>None<\/span><span class=\"gcs-score\">1<\/span><\/div>\n      <\/div>\n    <\/div>\n    <div class=\"gcs-block\">\n      <div class=\"gcs-header\">🗣 Verbal (V) max 5<\/div>\n      <div class=\"gcs-rows\">\n        <div class=\"gcs-row\"><span>Alert\/oriented<\/span><span class=\"gcs-score\">5<\/span><\/div>\n        <div class=\"gcs-row\"><span>Confused<\/span><span class=\"gcs-score\">4<\/span><\/div>\n        <div class=\"gcs-row\"><span>Inappropriate words<\/span><span class=\"gcs-score\">3<\/span><\/div>\n        <div class=\"gcs-row\"><span>Incomprehensible sounds<\/span><span class=\"gcs-score\">2<\/span><\/div>\n        <div class=\"gcs-row\"><span>None<\/span><span class=\"gcs-score\">1<\/span><\/div>\n      <\/div>\n    <\/div>\n    <div class=\"gcs-block\">\n      <div class=\"gcs-header\">💪 Motor (M) max 6<\/div>\n      <div class=\"gcs-rows\">\n        <div class=\"gcs-row\"><span>Obeys commands<\/span><span class=\"gcs-score\">6<\/span><\/div>\n        <div class=\"gcs-row\"><span>Localizes pain<\/span><span class=\"gcs-score\">5<\/span><\/div>\n        <div class=\"gcs-row\"><span>Withdrawal from pain<\/span><span class=\"gcs-score\">4<\/span><\/div>\n        <div class=\"gcs-row\"><span>Flexion (Decorticate)<\/span><span class=\"gcs-score\">3<\/span><\/div>\n        <div class=\"gcs-row\"><span>Extension (Decerebrate)<\/span><span class=\"gcs-score\">2<\/span><\/div>\n        <div class=\"gcs-row\"><span>None<\/span><span class=\"gcs-score\">1<\/span><\/div>\n      <\/div>\n    <\/div>\n  <\/div>\n  <div class=\"tbl-wrap\" style=\"margin-top:12px;\">\n    <table>\n      <thead><tr><th>GCS Score<\/th><th>Interpretation<\/th><th>Action<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><span class=\"badge badge-green\">≥13<\/span><\/td><td>Mild injury<\/td><td>Standard monitoring<\/td><\/tr>\n        <tr><td><span class=\"badge badge-orange\">8-12<\/span><\/td><td>Moderate injury<\/td><td>Close monitoring; consider imaging<\/td><\/tr>\n        <tr><td><span class=\"badge badge-red\">≤7<\/span><\/td><td>Severe trauma, poor clinical state<\/td><td>Can intubate at ≤8<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n\n  <!-- MENINGEAL SIGNS -->\n  <h3 class=\"subsection\">Meningeal Signs<\/h3>\n  <div class=\"grid-2\">\n    <div class=\"card\">\n      <div class=\"card-title\">Brudzinski's Sign (\"Batok\" Sign)<\/div>\n      <p style=\"font-size:0.88rem;\"><strong>Elicitation:<\/strong> Flex patient's neck<br><strong>Positive:<\/strong> Flexion of patient's knees<br><strong>Mnemonic:<\/strong> BFF (Brudzinski — Flex — Flex)<\/p>\n    <\/div>\n    <div class=\"card\">\n      <div class=\"card-title\">Kernig's Sign (\"Knee\" Sign)<\/div>\n      <p style=\"font-size:0.88rem;\"><strong>Elicitation:<\/strong> Flex patient's hip 90°, then extend knee<br><strong>Positive:<\/strong> Pain\/resistance to extension<br><strong>Mnemonic:<\/strong> KFE (Kernig — Flex hip — Extend knee → pain)<\/p>\n    <\/div>\n  <\/div>\n\n  <!-- EOM\/REFLEXES IN COMA -->\n  <h3 class=\"subsection\">Oculomotor Tests in Coma<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Test<\/th><th>Procedure<\/th><th>Normal (Intact Brainstem)<\/th><th>Abnormal<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td><strong>Doll's Eye (Oculocephalic) Reflex<\/strong><\/td><td>Move head horizontally (if no C-spine injury)<\/td><td>Eyes move to OPPOSITE side (eyes stay central)<\/td><td>No doll's eye = lesion in afferent (CN VIII) or efferent (CN III, IV, VI) arc<\/td><\/tr>\n        <tr><td><strong>Cold Calorics (COWS)<\/strong><\/td><td>Cold water in ear → slow phase toward injected ear; fast phase (nystagmus) opposite<\/td><td>In ALERT: true nystagmus (slow + fast)<\/td><td>In COMA: only slow phase (no fast phase — normal for coma)<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n  <div class=\"mnemonic\">\n    <div class=\"mnemonic-label\">Caloric Testing — COWS<\/div>\n    <div class=\"mnemonic-text\">C-O-W-S: Cold Opposite, Warm Same<\/div>\n    <div class=\"mnemonic-expand\">Cold water → fast phase (nystagmus) to Opposite side | Warm water → fast phase to Same side<\/div>\n  <\/div>\n\n  <!-- KNOWN vs UNKNOWN APPROACH -->\n  <h3 class=\"subsection\">Approach to Coma Causes<\/h3>\n  <div class=\"grid-2\">\n    <div class=\"card\">\n      <div class=\"card-title\">✅ Known Cause<\/div>\n      <p style=\"font-size:0.86rem;margin-bottom:8px;\"><strong>Structural:<\/strong> TBI, SAH, ICH, ischemic stroke, CNS infection, tumors<\/p>\n      <p style=\"font-size:0.86rem;margin-bottom:8px;\"><strong>Metabolic (STAT correct):<\/strong> Hypoxia, hypercarbia, fluid\/electrolyte, endocrine, toxins, vitamin deficiency<\/p>\n      <p style=\"font-size:0.86rem;\"><strong>Physiologic:<\/strong> If normal scan + normal labs + still comatose → <strong>STAT EEG<\/strong> (look for subclinical status epilepticus)<\/p>\n    <\/div>\n    <div class=\"card\">\n      <div class=\"card-title\">❓ Unknown Cause<\/div>\n      <div class=\"steps\" style=\"gap:6px;\">\n        <div class=\"step\" style=\"padding:10px 14px;\">\n          <div class=\"step-num\" style=\"width:22px;height:22px;font-size:0.75rem;\">1<\/div>\n          <div class=\"step-content\" style=\"font-size:0.85rem;\">Good history &amp; PE<\/div>\n        <\/div>\n        <div class=\"step\" style=\"padding:10px 14px;\">\n          <div class=\"step-num\" style=\"width:22px;height:22px;font-size:0.75rem;\">2<\/div>\n          <div class=\"step-content\" style=\"font-size:0.85rem;\">Repeat CT\/MRI brain<\/div>\n        <\/div>\n        <div class=\"step\" style=\"padding:10px 14px;\">\n          <div class=\"step-num\" style=\"width:22px;height:22px;font-size:0.75rem;\">3<\/div>\n          <div class=\"step-content\" style=\"font-size:0.85rem;\">Metabolic workup<\/div>\n        <\/div>\n        <div class=\"step\" style=\"padding:10px 14px;\">\n          <div class=\"step-num\" style=\"width:22px;height:22px;font-size:0.75rem;\">4<\/div>\n          <div class=\"step-content\" style=\"font-size:0.85rem;\"><strong>cEEG<\/strong> — if still asleep after correcting structural\/metabolic cause (beyond 30-min EEG; can run 48 hrs)<\/div>\n        <\/div>\n      <\/div>\n    <\/div>\n  <\/div>\n<\/div>\n\n<!-- ============================================================ -->\n<!-- TAB 5: MCQ -->\n<!-- ============================================================ -->\n<div id=\"mcq\" class=\"tab-content\">\n  <h2 class=\"section-title\">MCQ Practice Questions<\/h2>\n  <p class=\"section-subtitle\">Click an option to answer, then reveal the explanation<\/p>\n\n  <div class=\"mcq-container\" id=\"mcqContainer\">\n    <!-- Q1 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q1<\/span>A patient has loss of pain and temperature on the right leg starting at the umbilicus, with intact vibration sense. Where is the lesion?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Right dorsal column at T10<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">B<\/span>Left spinothalamic tract at T8<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">C<\/span>Right spinothalamic tract at T10<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>Left dorsal column at T10<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: B.<\/strong> Pain &amp; temperature = spinothalamic tract. ST fibers cross <strong>1-2 levels above entry<\/strong>, so sensory loss on the right means lesion is on the <strong>LEFT<\/strong>. Umbilicus ≈ T10 → lesion is approximately <strong>T8<\/strong>.<\/div>\n    <\/div>\n\n    <!-- Q2 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q2<\/span>A diabetic patient reports frequent falls at night and difficulty knowing where her feet are unless she looks at them. Which sensory modality is primarily affected?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Pain<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">B<\/span>Temperature<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">C<\/span>Proprioception<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>Crude touch<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: C.<\/strong> Falls in the dark + dependence on visual cues = <strong>loss of proprioception<\/strong> (DCML pathway). <strong>Positive Romberg<\/strong> = sways only after closing eyes. Common in diabetic polyneuropathy.<\/div>\n    <\/div>\n\n    <!-- Q3 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q3<\/span>A patient feels pain when a cotton swab lightly touches his cheek. This best describes:<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Hyperalgesia<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">B<\/span>Dysesthesia<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">C<\/span>Allodynia<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>Paresthesia<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: C.<\/strong> <strong>Allodynia<\/strong> = pain from a normally NON-painful stimulus. Classic in trigeminal neuralgia. Hyperalgesia = exaggerated pain from a painful stimulus. Paresthesia = pins &amp; needles (not painful). Dysesthesia = unpleasant abnormal sensation.<\/div>\n    <\/div>\n\n    <!-- Q4 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q4<\/span>Patient presents with bilateral loss of pain and temperature at the shoulders, with preserved vibration and proprioception. What is the most likely diagnosis?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Brown-Séquard syndrome<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">B<\/span>Syringomyelia<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">C<\/span>Cervical radiculopathy<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>Large fiber polyneuropathy<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: B.<\/strong> <strong>Syringomyelia<\/strong> (central cord) damages crossing spinothalamic fibers → bilateral loss of pain &amp; temperature at the level of the lesion. DCML (vibration, proprioception) is spared = \"cape\" or \"suspended\" sensory pattern.<\/div>\n    <\/div>\n\n    <!-- Q5 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q5<\/span>A 72-year-old man suddenly develops right-sided weakness with MORE weakness in the right leg than right arm. Which artery is most likely occluded?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Left middle cerebral artery<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">B<\/span>Right middle cerebral artery<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">C<\/span>Left anterior cerebral artery<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>Right internal capsule<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: C.<\/strong> ACA supplies the medial primary motor cortex (leg area). Leg &gt; arm weakness → ACA territory. Since weakness is on the right, lesion is on the LEFT.<\/div>\n    <\/div>\n\n    <!-- Q6 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q6<\/span>A patient has left-sided facial palsy including the forehead, with normal arm and leg power. What is the most likely diagnosis?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Right MCA stroke<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">B<\/span>Central facial palsy<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">C<\/span>Bell's Palsy (peripheral facial palsy)<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>Left internal capsule infarct<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: C.<\/strong> Forehead involvement + normal arms\/legs = peripheral facial palsy (Bell's palsy). Central (UMN) palsy SPARES the forehead (bilateral cortical innervation). Bell's palsy NEVER has arm\/leg weakness. Most common ER mimicker!<\/div>\n    <\/div>\n\n    <!-- Q7 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q7<\/span>A 58-year-old man has progressive asymmetric hand weakness with atrophy, fasciculations, and hyperreflexia in the lower extremities. Sensation is intact. What is the most likely diagnosis?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Peripheral neuropathy<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">B<\/span>Cervical radiculopathy<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">C<\/span>Myasthenia Gravis<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">D<\/span>ALS (Amyotrophic Lateral Sclerosis)<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: D.<\/strong> ALS = UMN signs (hyperreflexia) + LMN signs (atrophy, fasciculations). No sensory loss (motor neuron disease). Combination of UMN + LMN = anterior horn cell disease. Progressive course is classic.<\/div>\n    <\/div>\n\n    <!-- Q8 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q8<\/span>A 65-year-old smoker presents with proximal leg weakness that IMPROVES after repeated movement. Reflexes are decreased but improve after exercise. Sensation is intact. What is the diagnosis?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Myasthenia gravis<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">B<\/span>Lambert-Eaton Myasthenic Syndrome<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">C<\/span>Polymyositis<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>Radiculopathy<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: B.<\/strong> LEMS classic triad: (1) proximal weakness that IMPROVES with use (pre-synaptic Ca²⁺ channel autoantibodies), (2) hyporeflexia that improves with exercise, (3) associated with small cell <strong>lung cancer<\/strong>. Opposite of MG (which WORSENS with use).<\/div>\n    <\/div>\n\n    <!-- Q9 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q9<\/span>A comatose patient has pinpoint pupils that are reactive to light, preserved oculocephalic reflexes, and flaccid tone. What is the most likely etiology?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Pontine hemorrhage<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">B<\/span>Opioid intoxication<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">C<\/span>Thalamic infarction<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>Basilar artery thrombosis<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: B.<\/strong> Pinpoint pupils that are <strong>reactive<\/strong> + preserved brainstem reflexes = metabolic\/toxic cause. <strong>Opioid intoxication<\/strong> classically causes this. Pontine hemorrhage → pinpoint but NON-reactive. KEY: Reactive pinpoint = PNS intact → opioids\/metabolic, not structural pons.<\/div>\n    <\/div>\n\n    <!-- Q10 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q10<\/span>A patient opens eyes to voice (E3), speaks confused words (V4), and withdraws from pain (M4). What is the GCS?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>9<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">B<\/span>10<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">C<\/span>11<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>12<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: C.<\/strong> E3 + V4 + M4 = <strong>11<\/strong>. This is in the moderate injury range (8-12). Moderate injury requires close monitoring and imaging. Can intubate at GCS ≤8.<\/div>\n    <\/div>\n\n    <!-- Q11 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q11<\/span>A patient presents with hoarseness, dysphagia, left-sided facial sensory loss, left-sided Horner's syndrome, ipsilateral cerebellar ataxia, and RIGHT-sided loss of pain\/temperature of the body. What syndrome is this?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Weber syndrome<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">B<\/span>Wallenberg syndrome (PICA territory)<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">C<\/span>Brown-Séquard syndrome<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>Benedikt's syndrome<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: B.<\/strong> <strong>Wallenberg (Lateral Medullary) syndrome<\/strong> = PICA infarct. Classic crossed deficit: ipsilateral face sensory loss + contralateral body pain\/temperature loss. Also: Horner's, hoarseness, dysphagia, ipsilateral ataxia. CN deficits are ipsilateral, tract deficits are contralateral.<\/div>\n    <\/div>\n\n    <!-- Q12 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q12<\/span>A comatose patient demonstrates extension of BOTH upper AND lower extremities to painful stimuli. This posture most likely indicates a lesion:<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Above the red nucleus (upper midbrain)<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">B<\/span>At the thalamus<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">C<\/span>Below the red nucleus (upper pontine)<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>At the cerebral cortex<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: C.<\/strong> <strong>Decerebrate posturing<\/strong> (extension of ALL extremities) = lesion BELOW the red nucleus = upper pons. This is worse prognosis than decorticate. Decorticate (above red nucleus\/upper midbrain) = upper flexion + lower extension. Remember: \"If decerebrate, you're in trouble.\"<\/div>\n    <\/div>\n\n    <!-- Q13 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q13<\/span>Which respiratory pattern most strongly suggests a lesion in the lower pons?<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Cheyne-Stokes respiration<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">B<\/span>Central neurogenic hyperventilation<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">C<\/span>Apneustic breathing<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">D<\/span>Cluster breathing<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: D.<\/strong> <strong>Cluster breathing<\/strong> = Lower pons. Apneustic = mid-pons. Central neurogenic hyperventilation = lower midbrain to upper pons. Cheyne-Stokes = cerebrum\/diencephalon. Mnemonic: from diencephalon to medulla → Cheyne-Stokes → CNH → Apneustic → Cluster → Ataxic.<\/div>\n    <\/div>\n\n    <!-- Q14 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q14<\/span>A 40-year-old has difficulty climbing stairs and rising from a chair. Weakness is symmetric and proximal. Reflexes are preserved. Sensation is normal. CK is elevated. The most likely localization is:<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Anterior horn cell<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">B<\/span>Peripheral nerve<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">C<\/span>NMJ<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">D<\/span>Muscle<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: D.<\/strong> Classic <strong>Polymyositis\/Myopathy<\/strong> presentation: proximal symmetric weakness + normal sensation + elevated CK + preserved reflexes (early). No fatigue = not NMJ. No sensory loss = not nerve root or peripheral nerve. CK is key marker for muscle disease.<\/div>\n    <\/div>\n\n    <!-- Q15 -->\n    <div class=\"mcq-card\">\n      <div class=\"mcq-q\"><span class=\"qnum\">Q15<\/span>The most common focal neuropathy is:<\/div>\n      <div class=\"mcq-options\">\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">A<\/span>Ulnar neuropathy<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'correct')\"><span class=\"opt-label\">B<\/span>Carpal tunnel syndrome (median nerve)<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">C<\/span>Radial nerve palsy<\/div>\n        <div class=\"mcq-option\" onclick=\"selectOption(this,'wrong')\"><span class=\"opt-label\">D<\/span>Peroneal nerve palsy<\/div>\n      <\/div>\n      <div class=\"mcq-actions\"><button class=\"btn-reveal\" onclick=\"revealExplain(this)\">Show Explanation<\/button><\/div>\n      <div class=\"mcq-explain\">✅ <strong>Answer: B.<\/strong> Carpal tunnel syndrome = most common focal neuropathy. Caused by median nerve compression at the wrist under the transverse carpal ligament. Symptoms: numbness\/tingling in ventral 1st-3rd + lateral half of 4th digit. Tinel's sign positive.<\/div>\n    <\/div>\n  <\/div>\n<\/div>\n\n<!-- ============================================================ -->\n<!-- TAB 6: BUZZWORDS -->\n<!-- ============================================================ -->\n<div id=\"buzz\" class=\"tab-content\">\n  <h2 class=\"section-title\">⚡ Buzzwords & Clinical Clues<\/h2>\n  <p class=\"section-subtitle\">See the clue → know the answer<\/p>\n\n  <h3 class=\"subsection\">Sensory<\/h3>\n  <div class=\"buzz-grid\">\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Pins &amp; needles, NOT unpleasant<\/div><div class=\"buzz-clue\">Positive symptom, spontaneous<\/div><div class=\"buzz-answer\">→ Paresthesia<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Can't sleep due to abnormal sensation<\/div><div class=\"buzz-clue\">Positive, unpleasant<\/div><div class=\"buzz-answer\">→ Dysesthesia<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Cotton swab causes pain<\/div><div class=\"buzz-clue\">Non-painful → painful<\/div><div class=\"buzz-answer\">→ Allodynia (trigeminal neuralgia)<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Falls at night \/ needs to watch feet<\/div><div class=\"buzz-clue\">Loss of visual cues<\/div><div class=\"buzz-answer\">→ Proprioception loss (DCML)<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Unaware of foot ulcers<\/div><div class=\"buzz-clue\">Can't feel injury<\/div><div class=\"buzz-answer\">→ Diabetic polyneuropathy (small fiber)<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Sways ONLY with eyes closed<\/div><div class=\"buzz-clue\">Romberg positive<\/div><div class=\"buzz-answer\">→ Proprioception loss<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Sways with eyes OPEN<\/div><div class=\"buzz-clue\">Romberg negative<\/div><div class=\"buzz-answer\">→ Cerebellar ataxia<\/div><\/div>\n    <div class=\"buzz-card green\"><div class=\"buzz-term\">Ipsilateral DCML loss + Contralateral ST loss<\/div><div class=\"buzz-clue\">Unilateral cord lesion<\/div><div class=\"buzz-answer\">→ Brown-Séquard syndrome<\/div><\/div>\n    <div class=\"buzz-card green\"><div class=\"buzz-term\">Cape\/shoulder-level bilateral pain-temp loss, DCML intact<\/div><div class=\"buzz-clue\">Central cord, suspended pattern<\/div><div class=\"buzz-answer\">→ Syringomyelia<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Angle of jaw numbness (not trigeminal)<\/div><div class=\"buzz-clue\">C2 innervates jaw angle<\/div><div class=\"buzz-answer\">→ Radiculopathy, NOT stroke<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Numbness suddenly in whole limb<\/div><div class=\"buzz-clue\">Entire limb = central<\/div><div class=\"buzz-answer\">→ Stroke (contralateral hemisphere)<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Acute sensory + aphasia<\/div><div class=\"buzz-clue\">Language + sensory = parietal cortex<\/div><div class=\"buzz-answer\">→ Parietal cortex lesion (MCA)<\/div><\/div>\n  <\/div>\n\n  <h3 class=\"subsection\">Motor — UMN<\/h3>\n  <div class=\"buzz-grid\">\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Velocity-dependent resistance → sudden release<\/div><div class=\"buzz-clue\">Tone on passive movement<\/div><div class=\"buzz-answer\">→ Spasticity (UMN) — clasp-knife<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Constant resistance throughout ROM<\/div><div class=\"buzz-clue\">Velocity-independent<\/div><div class=\"buzz-answer\">→ Rigidity (extrapyramidal) — lead-pipe<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Forehead SPARED, lower face weak<\/div><div class=\"buzz-clue\">Contralateral upper face dual innervation<\/div><div class=\"buzz-answer\">→ Central (UMN) facial palsy — STROKE<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Entire face (including forehead) weak, arms\/legs normal<\/div><div class=\"buzz-clue\">LMN CN VII<\/div><div class=\"buzz-answer\">→ Bell's Palsy (peripheral)<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Most common ER mimicker of stroke<\/div><div class=\"buzz-clue\">Bell's palsy — no arm\/leg weakness<\/div><div class=\"buzz-answer\">→ Bell's Palsy<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Electric shock down spine on neck flexion<\/div><div class=\"buzz-clue\">Cervical cord irritation<\/div><div class=\"buzz-answer\">→ Lhermitte's sign (MS, cervical myelopathy)<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Flick middle finger → thumb &amp; index flex<\/div><div class=\"buzz-clue\">UMN upper limb<\/div><div class=\"buzz-answer\">→ Hoffman's sign<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Great toe extends + toes fan on plantar stroke<\/div><div class=\"buzz-clue\">UMN sign<\/div><div class=\"buzz-answer\">→ Babinski sign<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">Dense hemiplegia face + arm + leg equal<\/div><div class=\"buzz-clue\">All packed together<\/div><div class=\"buzz-answer\">→ Internal capsule (posterior limb) infarct<\/div><\/div>\n    <div class=\"buzz-card red\"><div class=\"buzz-term\">CN III palsy + contralateral ataxia &amp; hemiplegia<\/div><div class=\"buzz-clue\">Midbrain tegmentum<\/div><div class=\"buzz-answer\">→ Benedikt's syndrome<\/div><\/div>\n  <\/div>\n\n  <h3 class=\"subsection\">Motor — LMN & PNS<\/h3>\n  <div class=\"buzz-grid\">\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Wrist drop<\/div><div class=\"buzz-clue\">Wrist extensors wiped out<\/div><div class=\"buzz-answer\">→ Radial nerve palsy<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Foot drop<\/div><div class=\"buzz-clue\">Dorsiflexion lost<\/div><div class=\"buzz-answer\">→ Peroneal nerve palsy (most common mononeuropathy of leg)<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Claw hand (4th &amp; 5th fingers)<\/div><div class=\"buzz-clue\">Interossei &amp; 3rd\/4th lumbricals lost<\/div><div class=\"buzz-answer\">→ Ulnar nerve palsy<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Tapping wrist → tingling in 1st-3rd fingers<\/div><div class=\"buzz-clue\">Tinel's sign<\/div><div class=\"buzz-answer\">→ Carpal tunnel (median nerve)<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Waiter's tip posture<\/div><div class=\"buzz-clue\">Shoulder dystocia, newborn<\/div><div class=\"buzz-answer\">→ Erb's palsy (C5-C6, upper trunk)<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Fatigable weakness, worse with use<\/div><div class=\"buzz-clue\">Waxing &amp; waning<\/div><div class=\"buzz-answer\">→ Myasthenia Gravis (post-synaptic)<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Improves with exercise, lung cancer association<\/div><div class=\"buzz-clue\">Pre-synaptic NMJ<\/div><div class=\"buzz-answer\">→ Lambert-Eaton Myasthenic Syndrome<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Progressive weakness → atrophy → dysphagia → respiratory failure<\/div><div class=\"buzz-clue\">Both UMN + LMN, no sensory<\/div><div class=\"buzz-answer\">→ ALS (no cure)<\/div><\/div>\n    <div class=\"buzz-card green\"><div class=\"buzz-term\">Ascending symmetric weakness, post-infection<\/div><div class=\"buzz-clue\">Polyradiculopathy<\/div><div class=\"buzz-answer\">→ GBS (Guillain-Barré Syndrome)<\/div><\/div>\n    <div class=\"buzz-card green\"><div class=\"buzz-term\">LP: elevated protein, normal cells<\/div><div class=\"buzz-clue\">Albuminocytologic dissociation<\/div><div class=\"buzz-answer\">→ GBS (AIDP)<\/div><\/div>\n    <div class=\"buzz-card\"><div class=\"buzz-term\">Proximal symmetric weakness + elevated CK<\/div><div class=\"buzz-clue\">No sensory, no fatigue<\/div><div class=\"buzz-answer\">→ Polymyositis \/ Myopathy<\/div><\/div>\n  <\/div>\n\n  <h3 class=\"subsection\">Altered Sensorium<\/h3>\n  <div class=\"buzz-grid\">\n    <div class=\"buzz-card purple\"><div class=\"buzz-term\">Small, reactive pupils (coma)<\/div><div class=\"buzz-clue\">Bilateral<\/div><div class=\"buzz-answer\">→ Diencephalon lesion OR metabolic encephalopathy<\/div><\/div>\n    <div class=\"buzz-card purple\"><div class=\"buzz-term\">Pinpoint pupils, reactive<\/div><div class=\"buzz-clue\">PNS intact, SNS lost<\/div><div class=\"buzz-answer\">→ Opioid intoxication (or metabolic); NOT pontine hemorrhage<\/div><\/div>\n    <div class=\"buzz-card purple\"><div class=\"buzz-term\">Pinpoint pupils, NON-reactive<\/div><div class=\"buzz-clue\">Bilateral SNS + PNS gone<\/div><div class=\"buzz-answer\">→ Pontine hemorrhage<\/div><\/div>\n    <div class=\"buzz-card purple\"><div class=\"buzz-term\">Mid-dilated, fixed pupils<\/div><div class=\"buzz-clue\">WORST reaction<\/div><div class=\"buzz-answer\">→ Midbrain lesion (both SNS &amp; PNS drives lost)<\/div><\/div>\n    <div class=\"buzz-card purple\"><div class=\"buzz-term\">One dilated, fixed pupil<\/div><div class=\"buzz-clue\">Ipsilateral<\/div><div class=\"buzz-answer\">→ CN III compression (uncal herniation)<\/div><\/div>\n    <div class=\"buzz-card purple\"><div class=\"buzz-term\">Decorticate → Decerebrate (progression)<\/div><div class=\"buzz-clue\">Downward herniation<\/div><div class=\"buzz-answer\">→ Worsening brainstem compression<\/div><\/div>\n    <div class=\"buzz-card purple\"><div class=\"buzz-term\">Symmetric withdrawal, normal CT<\/div><div class=\"buzz-clue\">No focal lesion<\/div><div class=\"buzz-answer\">→ Metabolic encephalopathy<\/div><\/div>\n    <div class=\"buzz-card purple\"><div class=\"buzz-term\">Flex neck → knee\/hip flex<\/div><div class=\"buzz-clue\">Meningeal sign<\/div><div class=\"buzz-answer\">→ Brudzinski's sign (BFF)<\/div><\/div>\n    <div class=\"buzz-card purple\"><div class=\"buzz-term\">Flex hip 90° → extend knee → pain<\/div><div class=\"buzz-clue\">Meningeal sign<\/div><div class=\"buzz-answer\">→ Kernig's sign (KFE)<\/div><\/div>\n    <div class=\"buzz-card purple\"><div class=\"buzz-term\">Asleep, no visible seizures, persistent coma<\/div><div class=\"buzz-clue\">Normal scan + normal metabolic<\/div><div class=\"buzz-answer\">→ STAT EEG (rule out non-convulsive status epilepticus)<\/div><\/div>\n  <\/div>\n\n  <h3 class=\"subsection\">Stroke Localization Quick Reference<\/h3>\n  <div class=\"tbl-wrap\">\n    <table>\n      <thead><tr><th>Presentation<\/th><th>Artery \/ Location<\/th><\/tr><\/thead>\n      <tbody>\n        <tr><td>Leg &gt; arm weakness (contralateral)<\/td><td>ACA<\/td><\/tr>\n        <tr><td>Arm &amp; face &gt; leg weakness + aphasia (dominant) or neglect (non-dominant)<\/td><td>MCA<\/td><\/tr>\n        <tr><td>Vision loss (hemianopia)<\/td><td>PCA<\/td><\/tr>\n        <tr><td>Dense hemiplegia (face + arm + leg) equal<\/td><td>Internal capsule (lenticulostriate → small vessel)<\/td><\/tr>\n        <tr><td>Crossed deficits (CN ipsilateral + tract contralateral)<\/td><td>Brainstem<\/td><\/tr>\n        <tr><td>Ataxia + CN involvement<\/td><td>Brainstem\/Posterior fossa<\/td><\/tr>\n        <tr class=\"hi-row\"><td>Thalamic pain\/Dejerine-Roussy (chronic pain, half body)<\/td><td>Thalamus (VPL nucleus)<\/td><\/tr>\n        <tr><td>Acute hemorrhage on CT = hyperdense<\/td><td>MC location: Basal ganglia (putamen)<\/td><\/tr>\n      <\/tbody>\n    <\/table>\n  <\/div>\n<\/div>\n\n<!-- ============================================================ -->\n<!-- TAB 7: ALGORITHMS -->\n<!-- ============================================================ -->\n<div id=\"flow\" class=\"tab-content\">\n  <h2 class=\"section-title\">🗺 Clinical Algorithms & Quick Flowcharts<\/h2>\n  <p class=\"section-subtitle\">Step-by-step approaches to key clinical scenarios<\/p>\n\n  <!-- ALGORITHM 1: SENSORY -->\n  <div class=\"flowchart\">\n    <div class=\"flow-title\">Algorithm 1: Approach to Sensory Symptoms<\/div>\n    <div class=\"flow-container\">\n      <div class=\"flow-box start\">Patient with Sensory Complaint<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box question\">Step 1: Clarify — is it truly sensory? (not weakness\/non-neurologic)<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box action\">Step 2: Define distribution (dermatomal? glove-stocking? hemisensory?)<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box question\">Which pathway? Spinothalamic (pain\/temp) vs DCML (vib\/prop)?<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-branch\">\n        <div class=\"flow-branch-item\">\n          <div class=\"flow-branch-label\">Spinothalamic only<\/div>\n          <div class=\"flow-box result\">Contralateral cord lesion (crosses 1-2 levels above)<\/div>\n        <\/div>\n        <div class=\"flow-branch-item\">\n          <div class=\"flow-branch-label\">DCML only<\/div>\n          <div class=\"flow-box result\">Ipsilateral cord → medulla (dorsal column disease, B12 def)<\/div>\n        <\/div>\n        <div class=\"flow-branch-item\">\n          <div class=\"flow-branch-label\">Both pathways<\/div>\n          <div class=\"flow-box result\">Complete cord transection, thalamus, or cortex<\/div>\n        <\/div>\n      <\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box question\">Step 3: Check for associated features (cranial nerves, motor, reflexes)<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-branch\">\n        <div class=\"flow-branch-item\">\n          <div class=\"flow-branch-label\">Crossed + CN involvement<\/div>\n          <div class=\"flow-box danger\">Brainstem (Wallenberg, etc.)<\/div>\n        <\/div>\n        <div class=\"flow-branch-item\">\n          <div class=\"flow-branch-label\">Hemisensory + aphasia<\/div>\n          <div class=\"flow-box danger\">Parietal cortex (MCA)<\/div>\n        <\/div>\n        <div class=\"flow-branch-item\">\n          <div class=\"flow-branch-label\">Sensory level + bladder<\/div>\n          <div class=\"flow-box danger\">Spinal cord<\/div>\n        <\/div>\n      <\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box action\">Step 4: Temporal profile → Acute = vascular\/demyelination | Chronic = degenerative\/tumor<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box result\">Investigate: CT\/MRI, Labs (B12, glucose), EMG\/NCV, LP if myelopathy<\/div>\n    <\/div>\n  <\/div>\n\n  <!-- ALGORITHM 2: WEAKNESS -->\n  <div class=\"flowchart\">\n    <div class=\"flow-title\">Algorithm 2: Approach to Weakness<\/div>\n    <div class=\"flow-container\">\n      <div class=\"flow-box start\">Patient with Weakness<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box question\">Is it focal or generalized? Acute or chronic?<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box action\">Determine distribution: Hemi-? Para-? Quadri-? Proximal? Distal?<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box question\">UMN or LMN signs?<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-branch\">\n        <div class=\"flow-branch-item\">\n          <div class=\"flow-branch-label\">UMN Signs<br>(spasticity, hyperreflexia, Babinski)<\/div>\n          <div class=\"flow-box result\">Brain imaging (CT\/MRI brain or spinal MRI)<\/div>\n          <div class=\"flow-arrow\" style=\"font-size:0.9rem;\">↓<\/div>\n          <div class=\"flow-box action\">Localize: ACA (leg&gt;arm), MCA (arm&gt;leg), IC (equal), brainstem (crossed)<\/div>\n        <\/div>\n        <div class=\"flow-branch-item\">\n          <div class=\"flow-branch-label\">LMN Signs<br>(flaccid, hyporeflexia, atrophy)<\/div>\n          <div class=\"flow-box result\">EMG + NCV<\/div>\n          <div class=\"flow-arrow\" style=\"font-size:0.9rem;\">↓<\/div>\n          <div class=\"flow-box action\">Localize: AHC (ALS)? Root (pain)? Nerve (S&G)? NMJ (fatigue)? Muscle (proximal)?<\/div>\n        <\/div>\n      <\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box action\">Facial palsy assessment: Forehead spared (central) vs Forehead involved (peripheral)<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box result\">VITAMINS + DD for acute focal deficit (especially vascular = stroke)<\/div>\n    <\/div>\n  <\/div>\n\n  <!-- ALGORITHM 3: COMA -->\n  <div class=\"flowchart\">\n    <div class=\"flow-title\">Algorithm 3: Approach to Coma \/ Altered Sensorium<\/div>\n    <div class=\"flow-container\">\n      <div class=\"flow-box start\">Patient with Altered Sensorium \/ Coma<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box action\">Quick exam: SPERM (Sensorium · Pupils · EOM · Respiration · Motor)<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box question\">Asymmetric exam (reflexes, pupils, posturing)?<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-branch\">\n        <div class=\"flow-branch-item\">\n          <div class=\"flow-branch-label\">YES — Asymmetric<\/div>\n          <div class=\"flow-box danger\">STRUCTURAL CAUSE<br>→ Immediate CT\/MRI brain<\/div>\n          <div class=\"flow-arrow\" style=\"font-size:0.9rem;\">↓<\/div>\n          <div class=\"flow-box action\">TBI? SAH? ICH? Ischemic stroke? CNS infection? Tumor? ↑ICP?<\/div>\n        <\/div>\n        <div class=\"flow-branch-item\">\n          <div class=\"flow-branch-label\">NO — Symmetric<\/div>\n          <div class=\"flow-box result\">METABOLIC CAUSE LIKELY<br>→ STAT correct metabolic derangement<\/div>\n          <div class=\"flow-arrow\" style=\"font-size:0.9rem;\">↓<\/div>\n          <div class=\"flow-box action\">Hypoxia? Hypoglycemia? Drugs\/toxins? Electrolytes? Ammonia?<\/div>\n        <\/div>\n      <\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box question\">Still comatose after structural + metabolic workup?<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box danger\">STAT EEG \/ cEEG<br>Rule out non-convulsive status epilepticus<\/div>\n      <div class=\"flow-arrow\">↓<\/div>\n      <div class=\"flow-box action\">GCS for ongoing severity assessment (intubate if ≤8)<\/div>\n    <\/div>\n  <\/div>\n\n  <!-- LOCALIZATION QUICK TABLE -->\n  <div class=\"flowchart\">\n    <div class=\"flow-title\">Comprehensive Neuroanatomic Localization Summary<\/div>\n    <div class=\"tbl-wrap\">\n      <table class=\"loc-table\">\n        <thead>\n          <tr>\n            <th>Finding<\/th>\n            <th>Hemisphere<\/th>\n            <th>Brainstem<\/th>\n            <th>Cerebellum<\/th>\n            <th>Cord<\/th>\n            <th>AHC<\/th>\n            <th>Root<\/th>\n            <th>Nerve<\/th>\n            <th>NMJ<\/th>\n            <th>Muscle<\/th>\n          <\/tr>\n        <\/thead>\n        <tbody>\n          <tr><td><strong>Cognitive\/Seizure\/Aphasia<\/strong><\/td><td>✅<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><\/tr>\n          <tr><td><strong>Dysarthria<\/strong><\/td><td>✅<\/td><td>✅<\/td><td>✅<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>✅<\/td><td>—<\/td><\/tr>\n          <tr><td><strong>Visual field loss<\/strong><\/td><td>✅<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><\/tr>\n          <tr><td><strong>Bladder\/bowel<\/strong><\/td><td>—<\/td><td>✅<\/td><td>—<\/td><td>✅<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><\/tr>\n          <tr><td><strong>Atrophy<\/strong><\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>✅<\/td><td>✅<\/td><td>✅<\/td><td>—<\/td><td>✅<\/td><\/tr>\n          <tr><td><strong>Fasciculations<\/strong><\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>✅<\/td><td>✅<\/td><td>✅<\/td><td>—<\/td><td>—<\/td><\/tr>\n          <tr><td><strong>Upgoing toe (Babinski)<\/strong><\/td><td>✅<\/td><td>✅<\/td><td>—<\/td><td>✅<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><\/tr>\n          <tr><td><strong>Hyperreflexia<\/strong><\/td><td>✅<\/td><td>✅<\/td><td>—<\/td><td>✅<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><\/tr>\n          <tr><td><strong>Sensory loss<\/strong><\/td><td>✅<\/td><td>✅<\/td><td>—<\/td><td>✅<\/td><td>—<\/td><td>✅<\/td><td>✅<\/td><td>—<\/td><td>—<\/td><\/tr>\n          <tr><td><strong>Weakness<\/strong><\/td><td>✅<\/td><td>✅<\/td><td>—<\/td><td>✅<\/td><td>✅<\/td><td>✅<\/td><td>✅<\/td><td>✅<\/td><td>✅<\/td><\/tr>\n          <tr><td><strong>Pain (severe, dermatomal)<\/strong><\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>—<\/td><td>✅<\/td><td>✅<\/td><td>—<\/td><td>✅<\/td><\/tr>\n        <\/tbody>\n      <\/table>\n    <\/div>\n  <\/div>\n\n  <!-- KEY MNEMONICS SUMMARY -->\n  <div class=\"grid-2\">\n    <div class=\"mnemonic\">\n      <div class=\"mnemonic-label\">Stroke Localization<\/div>\n      <div class=\"mnemonic-text\">ACA = Ankles\/legs | MCA = Mouth-arm | IC = Infinite (all equal)<\/div>\n    <\/div>\n    <div class=\"mnemonic\">\n      <div class=\"mnemonic-label\">Coma Quick Exam<\/div>\n      <div class=\"mnemonic-text\">SPERM — Sensorium · Pupils · EOM · Respiration · Motor<\/div>\n    <\/div>\n    <div class=\"mnemonic\">\n      <div class=\"mnemonic-label\">Caloric Testing<\/div>\n      <div class=\"mnemonic-text\">COWS — Cold Opposite, Warm Same (fast phase direction)<\/div>\n    <\/div>\n    <div class=\"mnemonic\">\n      <div class=\"mnemonic-label\">Acute Focal Deficit DDx<\/div>\n      <div class=\"mnemonic-text\">VITAMINS + DD<\/div>\n      <div class=\"mnemonic-expand\">Vascular · Infection · Trauma · Autoimmune · Metabolic · Idiopathic · Nutritional · Seizure + Degenerative + Demyelinating<\/div>\n    <\/div>\n    <div class=\"mnemonic\">\n      <div class=\"mnemonic-label\">Brainstem \"4 Ds\"<\/div>\n      <div class=\"mnemonic-text\">Diplopia · Dysphagia · Dysarthria · Dizziness<\/div>\n    <\/div>\n    <div class=\"mnemonic\">\n      <div class=\"mnemonic-label\">DCML Memory Aids<\/div>\n      <div class=\"mnemonic-text\">Gracilis = Graceful Legs (below T6) | Cuneatus = Cervical\/arms<\/div>\n    <\/div>\n  <\/div>\n<\/div>\n\n<button class=\"scroll-top\" onclick=\"window.scrollTo({top:0,behavior:'smooth'})\">↑<\/button>\n\n<script>\n  function showTab(id) {\n    document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));\n    document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));\n    document.getElementById(id).classList.add('active');\n    event.target.classList.add('active');\n    window.scrollTo({top: 0, behavior: 'smooth'});\n  }\n\n  function selectOption(el, type) {\n    const card = el.closest('.mcq-card');\n    const options = card.querySelectorAll('.mcq-option');\n    if (options[0].classList.contains('revealed')) return;\n    options.forEach(opt => {\n      opt.classList.add('revealed');\n    });\n    el.classList.add(type);\n    if (type === 'wrong') {\n      options.forEach(opt => {\n        if (!opt.classList.contains('wrong') && !opt.classList.contains('correct')) {\n          \/\/ find the correct one\n        }\n      });\n    }\n  }\n\n  function revealExplain(btn) {\n    const card = btn.closest('.mcq-card');\n    const explain = card.querySelector('.mcq-explain');\n    explain.style.display = 'block';\n    btn.textContent = 'Explanation shown';\n    btn.disabled = true;\n    btn.style.opacity = '0.5';\n  }\n<\/script>\n\n<\/body>\n<\/html>\n",
