      <div class="step"><span class="sn">2 · 5–60 min (20%)</span><span class="sv">AURA</span><span style="font-size:11px">Visual (most common), sensory, language</span></div>
      <div class="step" style="background:#fff3cd"><span class="sn">3 · 4–72 hrs</span><span class="sv">HEADACHE</span><span style="font-size:11px">Severe, unilateral, pulsating</span></div>
      <div class="step"><span class="sn">4 · Hours–Days</span><span class="sv">POSTDROME</span><span style="font-size:11px">Fatigue, brain fog, neck stiffness</span></div>
