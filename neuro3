<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Neurosciences 1 — High Yield Reviewer</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap');

:root {
–bg: #f5f3ef;
–card: #ffffff;
–border: #e2ddd6;
–text: #2c2825;
–muted: #7a736b;

```
--diz: #4a7c59;    --diz-light: #edf5f0;    --diz-mid: #c2dccb;
--head: #7c5a3a;   --head-light: #fdf4ec;   --head-mid: #e8d0b8;
--mem: #3a5a7c;    --mem-light: #eff4fd;    --mem-mid: #bdd0e8;
--sz: #7c3a5a;     --sz-light: #fdefF4;     --sz-mid: #e8bdd0;

--danger: #c0392b; --danger-light: #fdf0ef;
--warn: #d4820a;   --warn-light: #fef9ec;
--ok: #27ae60;     --ok-light: #edfaf3;
--info: #2980b9;   --info-light: #eef6fc;

--rad: 10px;
--shadow: 0 2px 12px rgba(0,0,0,0.07);
```

}

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
font-family: ‘DM Sans’, sans-serif;
background: var(–bg);
color: var(–text);
font-size: 14px;
line-height: 1.6;
}

/* ── Header ── */
.site-header {
background: var(–text);
color: #fff;
padding: 24px 32px;
text-align: center;
}
.site-header h1 {
font-family: ‘Playfair Display’, serif;
font-size: 2rem;
letter-spacing: .5px;
}
.site-header p { color: #bbb; font-size: 13px; margin-top: 4px; }

/* ── Tab Nav ── */
.tab-nav {
display: flex;
gap: 0;
background: #fff;
border-bottom: 2px solid var(–border);
position: sticky;
top: 0;
z-index: 100;
overflow-x: auto;
}
.tab-btn {
padding: 14px 24px;
border: none;
background: none;
font-family: ‘DM Sans’, sans-serif;
font-size: 13px;
font-weight: 500;
cursor: pointer;
color: var(–muted);
border-bottom: 3px solid transparent;
white-space: nowrap;
transition: all .2s;
}
.tab-btn:hover { color: var(–text); background: var(–bg); }
.tab-btn.active { color: var(–text); font-weight: 600; border-bottom-color: var(–text); }
.tab-btn.t0.active { border-bottom-color: var(–diz); color: var(–diz); }
.tab-btn.t1.active { border-bottom-color: var(–head); color: var(–head); }
.tab-btn.t2.active { border-bottom-color: var(–mem); color: var(–mem); }
.tab-btn.t3.active { border-bottom-color: var(–sz); color: var(–sz); }
.tab-btn.t4.active { border-bottom-color: #555; color: #555; }

/* ── Tab Panels ── */
.tab-panel { display: none; padding: 28px 32px; max-width: 1100px; margin: 0 auto; }
.tab-panel.active { display: block; }

/* ── Section ── */
.section { margin-bottom: 32px; }
.section-title {
font-family: ‘Playfair Display’, serif;
font-size: 1.25rem;
margin-bottom: 14px;
padding-bottom: 8px;
border-bottom: 2px solid var(–border);
}
.sub-title {
font-size: 13px;
font-weight: 600;
text-transform: uppercase;
letter-spacing: .8px;
margin: 16px 0 8px;
color: var(–muted);
}

/* ── Cards ── */
.card {
background: var(–card);
border: 1px solid var(–border);
border-radius: var(–rad);
padding: 18px;
margin-bottom: 14px;
box-shadow: var(–shadow);
}
.card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.card-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
@media (max-width: 700px) { .card-grid, .card-grid-3 { grid-template-columns: 1fr; } }

.badge {
display: inline-block;
padding: 2px 10px;
border-radius: 20px;
font-size: 11px;
font-weight: 600;
margin-bottom: 8px;
}
.badge-diz { background: var(–diz-mid); color: var(–diz); }
.badge-head { background: var(–head-mid); color: var(–head); }
.badge-mem { background: var(–mem-mid); color: var(–mem); }
.badge-sz { background: var(–sz-mid); color: var(–sz); }
.badge-danger { background: #fce8e6; color: var(–danger); }
.badge-ok { background: #e6f7ed; color: var(–ok); }
.badge-warn { background: #fef3dc; color: var(–warn); }

/* ── Tables ── */
.tbl-wrap { overflow-x: auto; margin-bottom: 14px; }
table { width: 100%; border-collapse: collapse; font-size: 13px; background: var(–card); border-radius: var(–rad); overflow: hidden; box-shadow: var(–shadow); }
th { background: var(–text); color: #fff; padding: 10px 14px; text-align: left; font-size: 12px; font-weight: 600; letter-spacing: .4px; }
td { padding: 9px 14px; border-bottom: 1px solid var(–border); vertical-align: top; }
tr:last-child td { border-bottom: none; }
tr:nth-child(even) td { background: #faf9f7; }
.th-diz { background: var(–diz) !important; }
.th-head { background: var(–head) !important; }
.th-mem { background: var(–mem) !important; }
.th-sz { background: var(–sz) !important; }

/* ── Highlight boxes ── */
.hbox {
border-left: 4px solid;
padding: 12px 16px;
border-radius: 0 var(–rad) var(–rad) 0;
margin-bottom: 12px;
font-size: 13px;
}
.hbox-danger { border-color: var(–danger); background: var(–danger-light); }
.hbox-warn { border-color: var(–warn); background: var(–warn-light); }
.hbox-ok { border-color: var(–ok); background: var(–ok-light); }
.hbox-info { border-color: var(–info); background: var(–info-light); }
.hbox-diz { border-color: var(–diz); background: var(–diz-light); }
.hbox-head { border-color: var(–head); background: var(–head-light); }
.hbox-mem { border-color: var(–mem); background: var(–mem-light); }
.hbox-sz { border-color: var(–sz); background: var(–sz-light); }
.hbox strong { display: block; margin-bottom: 4px; }

/* ── Key facts ── */
ul.kf { list-style: none; padding: 0; }
ul.kf li { padding: 4px 0 4px 20px; position: relative; font-size: 13px; }
ul.kf li::before { content: ‘▸’; position: absolute; left: 0; color: var(–muted); }
ul.kf li.star::before { content: ‘⭐’; font-size: 12px; }
ul.kf li.danger::before { content: ‘🚨’; font-size: 12px; }
ul.kf li.ok::before { content: ‘✅’; font-size: 12px; }

em.hl { background: #fff3cd; padding: 1px 4px; border-radius: 3px; font-style: normal; font-weight: 600; }
code { font-family: ‘DM Mono’, monospace; background: #f0ede8; padding: 1px 5px; border-radius: 3px; font-size: 12px; }

/* ── Flowchart ── */
.flow { display: flex; flex-direction: column; align-items: center; gap: 0; }
.flow-box {
background: var(–card);
border: 2px solid var(–border);
border-radius: var(–rad);
padding: 10px 20px;
text-align: center;
font-size: 13px;
font-weight: 500;
min-width: 220px;
max-width: 340px;
box-shadow: var(–shadow);
}
.flow-arr { font-size: 22px; color: var(–muted); line-height: 1; padding: 2px 0; }
.flow-row { display: flex; gap: 16px; align-items: flex-start; justify-content: center; flex-wrap: wrap; }
.flow-col { display: flex; flex-direction: column; align-items: center; }
.flow-diz .flow-box { border-color: var(–diz); }
.flow-head .flow-box { border-color: var(–head); }
.flow-mem .flow-box { border-color: var(–mem); }
.flow-sz .flow-box { border-color: var(–sz); }
.flow-danger .flow-box { border-color: var(–danger); background: var(–danger-light); }
.flow-ok .flow-box { border-color: var(–ok); background: var(–ok-light); }

/* ── MCQ ── */
.mcq-item {
background: var(–card);
border: 1px solid var(–border);
border-radius: var(–rad);
padding: 18px;
margin-bottom: 14px;
box-shadow: var(–shadow);
}
.mcq-q { font-weight: 600; margin-bottom: 10px; font-size: 13.5px; }
.mcq-opts { list-style: none; }
.mcq-opts li {
padding: 7px 12px;
border-radius: 6px;
margin-bottom: 5px;
border: 1px solid var(–border);
cursor: pointer;
font-size: 13px;
transition: all .15s;
}
.mcq-opts li:hover { background: var(–bg); }
.mcq-opts li.correct { background: var(–ok-light); border-color: var(–ok); color: var(–ok); font-weight: 600; }
.mcq-opts li.wrong { background: var(–danger-light); border-color: var(–danger); color: var(–danger); text-decoration: line-through; }
.mcq-exp {
display: none;
margin-top: 10px;
padding: 10px 14px;
background: var(–info-light);
border-left: 3px solid var(–info);
border-radius: 0 6px 6px 0;
font-size: 13px;
color: #1a5276;
}
.mcq-exp.show { display: block; }
.mcq-tag { font-size: 11px; font-weight: 600; color: var(–muted); margin-bottom: 6px; }

/* ── Buzzword pills ── */
.buzz-grid { display: flex; flex-wrap: wrap; gap: 8px; }
.buzz {
display: inline-flex;
flex-direction: column;
padding: 8px 14px;
border-radius: 8px;
border: 1px solid var(–border);
background: var(–card);
font-size: 12px;
}
.buzz strong { font-size: 13px; font-weight: 600; }
.buzz span { color: var(–muted); font-size: 11px; }

/* ── Compare strips ── */
.vs { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; border-radius: var(–rad); overflow: hidden; border: 1px solid var(–border); margin-bottom: 14px; }
.vs-a { background: var(–danger-light); padding: 14px; }
.vs-b { background: var(–ok-light); padding: 14px; }
.vs h4 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 8px; }
.vs-a h4 { color: var(–danger); }
.vs-b h4 { color: var(–ok); }

/* ── Progress stepper ── */
.stepper { display: flex; gap: 0; margin-bottom: 14px; }
.step { flex: 1; background: var(–card); border: 1px solid var(–border); border-right: none; padding: 10px 12px; font-size: 12px; position: relative; }
.step:last-child { border-right: 1px solid var(–border); border-radius: 0 var(–rad) var(–rad) 0; }
.step:first-child { border-radius: var(–rad) 0 0 var(–rad); }
.step .sn { display: block; font-size: 10px; font-weight: 700; color: var(–muted); text-transform: uppercase; letter-spacing: .5px; }
.step .sv { display: block; font-size: 12px; font-weight: 600; margin-top: 2px; }

/* Score bars */
.score-bar { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
.score-bar .label { font-size: 12px; min-width: 80px; }
.bar-track { flex: 1; height: 8px; background: var(–border); border-radius: 4px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 4px; }

/* ── Mnemonic box ── */
.mnemonic {
background: linear-gradient(135deg, #fff8e1, #fff3cd);
border: 2px solid #f9c740;
border-radius: var(–rad);
padding: 16px 20px;
margin-bottom: 14px;
text-align: center;
}
.mnemonic .mn-word { font-family: ‘Playfair Display’, serif; font-size: 2rem; color: var(–warn); letter-spacing: 8px; }
.mnemonic .mn-expand { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; margin-top: 8px; }
.mnemonic .mn-item { font-size: 12px; }
.mnemonic .mn-item strong { display: block; font-size: 16px; color: var(–warn); font-family: ‘Playfair Display’, serif; }

/* hints diagram */
.hints-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 14px; }
.hints-card { background: var(–card); border: 2px solid var(–diz-mid); border-radius: var(–rad); padding: 14px; text-align: center; }
.hints-card .letter { font-family: ‘Playfair Display’, serif; font-size: 2.5rem; color: var(–diz); }
.hints-card .hname { font-weight: 700; font-size: 13px; margin-bottom: 6px; }
.hints-card .hdesc { font-size: 12px; color: var(–muted); }
.hints-card .hresult { margin-top: 8px; font-size: 12px; }

/* ── Aphasia table coloring ── */
.yes { color: var(–ok); font-weight: 700; }
.no { color: var(–danger); font-weight: 700; }

.tag { display: inline-block; font-size: 10px; padding: 1px 6px; border-radius: 3px; font-weight: 600; margin-left: 4px; background: #eee; color: #555; }
.tag-r { background: #fce8e6; color: #c0392b; }
.tag-g { background: #e6f7ed; color: #27ae60; }
</style>

</head>
