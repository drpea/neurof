<script>
function showTab(n) {
  document.querySelectorAll('.tab-panel').forEach((p,i) => p.classList.toggle('active', i===n));
  document.querySelectorAll('.tab-btn').forEach((b,i) => b.classList.toggle('active', i===n));
  window.scrollTo(0,0);
}

function handleMCQ(e, list, correctIdx) {
  const items = list.querySelectorAll('li');
  if ([...items].some(i => i.classList.contains('correct') || i.classList.contains('wrong'))) return;
  const clicked = e.target.closest('li');
  if (!clicked) return;
  const clickedIdx = [...items].indexOf(clicked);
  items.forEach((item, i) => {
    if (i === correctIdx) item.classList.add('correct');
    else if (i === clickedIdx && clickedIdx !== correctIdx) item.classList.add('wrong');
  });
  const exp = list.closest('.mcq-item').querySelector('.mcq-exp');
  exp.classList.add('show');
}
</script>

